with "../tls_core/tls_core.gpr";

project Tls_Transport is

   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Library_Name use "tls_transport";
   for Library_Dir use "lib";
   for Library_Kind use "static";

   package Compiler is
      for Default_Switches ("Ada") use
        ("-gnat2022", "-gnatwa", "-gnatyM120", "-gnato",
         "-fstack-check", "-g", "-O1");
   end Compiler;

end Tls_Transport;
