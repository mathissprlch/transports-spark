library project Http1_Core is

   for Library_Name use "http1_core";
   for Library_Kind use "static";
   for Source_Dirs use ("src", "src/transport_tcp");
   for Object_Dir use "obj";
   for Library_Dir use "lib";
   for Create_Missing_Dirs use "True";

   package Compiler is
      for Default_Switches ("Ada") use
        ("-g", "-O0", "-gnat2022", "-gnatwa", "-gnatVa", "-gnatyM100", "-gnata");
   end Compiler;

end Http1_Core;
