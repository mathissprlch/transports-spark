                 when S_Sending | S_Awaiting_Puback =>
                    True,
                 when others =>
                    False),
          when C_App_Pending =>
             (case St is
                 when S_Forwarding_Inbound_Publish | S_Forwarding_Puback =>
                    True,
                 when others =>
                    False),
          when C_App_Outbox =>
             (case St is
                 when S_Loading =>
                    True,
                 when others =>
                    False));

