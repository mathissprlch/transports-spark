     (case Chan is
          when C_Network =>
             (case Ctx.P.Next_State is
                 when S_Awaiting_Puback =>
                    Control_Packet.Incoming_Packet.Buffer_Length (Ctx.P.Inbound_Ctx),
                 when others =>
                    RFLX_Types.Unreachable),
          when C_App_Pending =>
             0,
          when C_App_Outbox =>
             (case Ctx.P.Next_State is
                 when S_Loading =>
                    Publish.Packet.Buffer_Length (Ctx.P.Outgoing_Ctx),
                 when others =>
                    RFLX_Types.Unreachable));

