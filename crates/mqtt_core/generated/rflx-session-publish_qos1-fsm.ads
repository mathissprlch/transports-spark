          when C_Network =>
             (case St is
                 when S_Sending =>
                    B_Outgoing,
                 when S_Awaiting_Puback =>
                    B_Inbound,
                 when others =>
                    Unreachable_External_Buffer),
          when C_App_Pending =>
             (case St is
                 when S_Forwarding_Inbound_Publish | S_Forwarding_Puback =>
                    B_Inbound,
                 when others =>
                    Unreachable_External_Buffer),
          when C_App_Outbox =>
             (case St is
                 when S_Loading =>
                    B_Outgoing,
                 when others =>
                    Unreachable_External_Buffer));

