      with procedure Process_Payload (Payload : out RFLX_Types.Bytes);
      with function Process_Data_Pre (Length : RFLX_Types.Length) return Boolean;
   procedure Generic_Set_Payload (Ctx : in out Context; Length : RFLX_Types.Length)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.Publish.Packet.Has_Buffer (Ctx)
       and then RFLX.Publish.Packet.Valid_Next (Ctx, RFLX.Publish.Packet.F_Payload)
       and then RFLX.Publish.Packet.Available_Space (Ctx, RFLX.Publish.Packet.F_Payload) >= RFLX.Publish.Packet.Field_Size (Ctx, RFLX.Publish.Packet.F_Payload)
       and then RFLX.Publish.Packet.Valid_Length (Ctx, RFLX.Publish.Packet.F_Payload, Length)
       and then RFLX_Types.To_Length (RFLX.Publish.Packet.Available_Space (Ctx, RFLX.Publish.Packet.F_Payload)) >= Length
       and then Process_Data_Pre (Length),
     Post =>
       Has_Buffer (Ctx)
       and Well_Formed (Ctx, F_Payload)
       and (if Well_Formed_Message (Ctx) then Message_Last (Ctx) = Field_Last (Ctx, F_Payload))
       and Ctx.Buffer_First = Ctx.Buffer_First'Old
       and Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and Ctx.First = Ctx.First'Old
       and Ctx.Last = Ctx.Last'Old
       and Valid_Next (Ctx, F_Payload) = Valid_Next (Ctx, F_Payload)'Old
       and Get_Packet_Type (Ctx) = Get_Packet_Type (Ctx)'Old
       and Get_DUP (Ctx) = Get_DUP (Ctx)'Old
       and Get_QoS (Ctx) = Get_QoS (Ctx)'Old
       and Get_Remaining_Length (Ctx) = Get_Remaining_Length (Ctx)'Old
       and Get_Topic_Name_Length (Ctx) = Get_Topic_Name_Length (Ctx)'Old
       and Field_First (Ctx, F_Payload) = Field_First (Ctx, F_Payload)'Old;

   function Context_Cursor (Ctx : Context; Fld : Field) return Field_Cursor
   with
     Annotate =>
       (GNATprove, Inline_For_Proof),
     Ghost;

   function Context_Cursors (Ctx : Context) return Field_Cursors
   with
     Annotate =>
       (GNATprove, Inline_For_Proof),
     Ghost;

   function Context_Cursors_Index (Cursors : Field_Cursors; Fld : Field) return Field_Cursor
   with
     Annotate =>
       (GNATprove, Inline_For_Proof),
     Ghost;

private

   type Cursor_State is (S_Valid, S_Well_Formed, S_Invalid, S_Incomplete);

   type Field_Cursor is
      record
         State : Cursor_State := S_Invalid;
         First : RFLX_Types.Bit_Index := RFLX_Types.Bit_Index'First;
         Last : RFLX_Types.Bit_Length := RFLX_Types.Bit_Length'First;
         Value : RFLX_Types.Base_Integer := 0;
      end record;

   type Field_Cursors is array (Virtual_Field) of Field_Cursor;

   function Well_Formed (Cursor : Field_Cursor) return Boolean is
     (Cursor.State = S_Valid
      or Cursor.State = S_Well_Formed);

   function Valid (Cursor : Field_Cursor) return Boolean is
     (Cursor.State = S_Valid);

   function Invalid (Cursor : Field_Cursor) return Boolean is
     (Cursor.State = S_Invalid
      or Cursor.State = S_Incomplete);

   pragma Warnings (Off, "postcondition does not mention function result");

   function Cursors_Invariant (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length) return Boolean is
     ((for all F in Field =>
          (if
              Well_Formed (Cursors (F))
           then
              Cursors (F).First >= First
              and Cursors (F).Last <= Verified_Last
              and Cursors (F).First <= Cursors (F).Last + 1
              and Valid_Value (F, Cursors (F).Value))))
   with
     Post =>
       True;

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (Off, "formal parameter ""*"" is not referenced");

   pragma Warnings (Off, "postcondition does not mention function result");

   pragma Warnings (Off, "unused variable ""*""");

   function Valid_Predecessors_Invariant (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return Boolean is
     ((if Well_Formed (Cursors (F_Packet_Type)) then True)
      and then (if
                   Well_Formed (Cursors (F_DUP))
                then
                   (Valid (Cursors (F_Packet_Type))
                    and then RFLX_Types.Base_Integer (Cursors (F_Packet_Type).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.PUBLISH))))
      and then (if Well_Formed (Cursors (F_QoS)) then Valid (Cursors (F_DUP)))
      and then (if Well_Formed (Cursors (F_Retain)) then Valid (Cursors (F_QoS)))
      and then (if Well_Formed (Cursors (F_Remaining_Length)) then Valid (Cursors (F_Retain)))
      and then (if Well_Formed (Cursors (F_Topic_Name_Length)) then Valid (Cursors (F_Remaining_Length)))
      and then (if Well_Formed (Cursors (F_Topic_Name)) then Valid (Cursors (F_Topic_Name_Length)))
      and then (if
                   Well_Formed (Cursors (F_Packet_Identifier))
                then
                   (Well_Formed (Cursors (F_Topic_Name))
                    and then (RFLX_Types.Base_Integer (Cursors (F_QoS).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.QOS_1))
                              or else RFLX_Types.Base_Integer (Cursors (F_QoS).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.QOS_2)))
                    and then RFLX_Types.Base_Integer (Cursors (F_Remaining_Length).Value) >= RFLX_Types.Base_Integer (Cursors (F_Topic_Name_Length).Value) + 4))
      and then (if
                   Well_Formed (Cursors (F_Payload))
                then
                   Valid (Cursors (F_Packet_Identifier))
                   or (Well_Formed (Cursors (F_Topic_Name))
                       and then RFLX_Types.Base_Integer (Cursors (F_QoS).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.QOS_0))
                       and then RFLX_Types.Base_Integer (Cursors (F_Remaining_Length).Value) >= RFLX_Types.Base_Integer (Cursors (F_Topic_Name_Length).Value) + 2)))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last),
     Post =>
       True;

   pragma Warnings (On, "unused variable ""*""");

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (On, "formal parameter ""*"" is not referenced");

   pragma Warnings (Off, "postcondition does not mention function result");

   function Valid_Next_Internal (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Fld : Field) return Boolean is
     (case Fld is
          when F_Packet_Type =>
             True,
          when F_DUP =>
             (Valid (Cursors (F_Packet_Type))
              and then RFLX_Types.Base_Integer (Cursors (F_Packet_Type).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.PUBLISH))),
          when F_QoS =>
             (Valid (Cursors (F_DUP))
              and then True),
          when F_Retain =>
             (Valid (Cursors (F_QoS))
              and then True),
          when F_Remaining_Length =>
             (Valid (Cursors (F_Retain))
              and then True),
          when F_Topic_Name_Length =>
             (Valid (Cursors (F_Remaining_Length))
              and then True),
          when F_Topic_Name =>
             (Valid (Cursors (F_Topic_Name_Length))
              and then True),
          when F_Packet_Identifier =>
             (Well_Formed (Cursors (F_Topic_Name))
              and then ((RFLX_Types.Base_Integer (Cursors (F_QoS).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.QOS_1))
                         or else RFLX_Types.Base_Integer (Cursors (F_QoS).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.QOS_2)))
                        and then RFLX_Types.Base_Integer (Cursors (F_Remaining_Length).Value) >= RFLX_Types.Base_Integer (Cursors (F_Topic_Name_Length).Value) + 4)),
          when F_Payload =>
             (Valid (Cursors (F_Packet_Identifier))
              and then True)
             or (Well_Formed (Cursors (F_Topic_Name))
                 and then (RFLX_Types.Base_Integer (Cursors (F_QoS).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.QOS_0))
                           and then RFLX_Types.Base_Integer (Cursors (F_Remaining_Length).Value) >= RFLX_Types.Base_Integer (Cursors (F_Topic_Name_Length).Value) + 2)))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last),
     Post =>
       True;

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (Off, "unused variable ""*""");

   pragma Warnings (Off, "formal parameter ""*"" is not referenced");

   function Field_Size_Internal (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Fld : Field) return RFLX_Types.Bit_Length'Base is
     (case Fld is
          when F_Packet_Type =>
             4,
          when F_DUP =>
             1,
          when F_QoS =>
             2,
          when F_Retain =>
             1,
          when F_Remaining_Length =>
             8,
          when F_Topic_Name_Length =>
             16,
          when F_Topic_Name =>
             RFLX_Types.Bit_Length (Cursors (F_Topic_Name_Length).Value) * 8,
          when F_Packet_Identifier =>
             16,
          when F_Payload =>
             (if
                 Well_Formed (Cursors (F_Packet_Identifier))
              then
                 RFLX_Types.Bit_Length (Cursors (F_Remaining_Length).Value) * 8 + RFLX_Types.Bit_Length (Cursors (F_Topic_Name_Length).Value) * (-8) - 32
              elsif
                 Well_Formed (Cursors (F_Topic_Name))
                 and then (RFLX_Types.Bit_Length (Cursors (F_QoS).Value) = RFLX_Types.Bit_Length (To_Base_Integer (RFLX.Control_Packet.QOS_0))
                           and then RFLX_Types.Bit_Length (Cursors (F_Remaining_Length).Value) >= RFLX_Types.Bit_Length (Cursors (F_Topic_Name_Length).Value) + 2)
              then
                 RFLX_Types.Bit_Length (Cursors (F_Remaining_Length).Value) * 8 + RFLX_Types.Bit_Length (Cursors (F_Topic_Name_Length).Value) * (-8) - 16
              else
                 RFLX_Types.Unreachable))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, Fld);

   pragma Warnings (On, "formal parameter ""*"" is not referenced");

   pragma Warnings (On, "unused variable ""*""");

   pragma Warnings (Off, "postcondition does not mention function result");

   pragma Warnings (Off, "unused variable ""*""");

   pragma Warnings (Off, "no recursive call visible");

   pragma Warnings (Off, "formal parameter ""*"" is not referenced");

   function Field_First_Packet_Type (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Packet_Type);

   function Field_First_DUP (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 4)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_DUP);

   function Field_First_QoS (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 5)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_QoS);

   function Field_First_Retain (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 7)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Retain);

   function Field_First_Remaining_Length (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 8)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Remaining_Length);

   function Field_First_Topic_Name_Length (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 16)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Topic_Name_Length);

   function Field_First_Topic_Name (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 32)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Topic_Name);

   function Field_First_Packet_Identifier (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (Field_First_Topic_Name (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Topic_Name))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Packet_Identifier);

   function Field_First_Payload (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (if
          Well_Formed (Cursors (F_Packet_Identifier))
          and then True
       then
          Field_First_Topic_Name (Cursors, First, Verified_Last, Written_Last) + (Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Topic_Name) + 16)
       elsif
          Well_Formed (Cursors (F_Topic_Name))
          and then (RFLX_Types.Base_Integer (Cursors (F_QoS).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.QOS_0))
                    and then RFLX_Types.Base_Integer (Cursors (F_Remaining_Length).Value) >= RFLX_Types.Base_Integer (Cursors (F_Topic_Name_Length).Value) + 2)
       then
          Field_First_Topic_Name (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Topic_Name)
       else
          RFLX_Types.Unreachable)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Payload);

   function Field_First_Internal (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Fld : Field) return RFLX_Types.Bit_Index'Base is
     (case Fld is
          when F_Packet_Type =>
             Field_First_Packet_Type (Cursors, First, Verified_Last, Written_Last),
          when F_DUP =>
             Field_First_DUP (Cursors, First, Verified_Last, Written_Last),
          when F_QoS =>
             Field_First_QoS (Cursors, First, Verified_Last, Written_Last),
          when F_Retain =>
             Field_First_Retain (Cursors, First, Verified_Last, Written_Last),
          when F_Remaining_Length =>
             Field_First_Remaining_Length (Cursors, First, Verified_Last, Written_Last),
          when F_Topic_Name_Length =>
             Field_First_Topic_Name_Length (Cursors, First, Verified_Last, Written_Last),
          when F_Topic_Name =>
             Field_First_Topic_Name (Cursors, First, Verified_Last, Written_Last),
          when F_Packet_Identifier =>
             Field_First_Packet_Identifier (Cursors, First, Verified_Last, Written_Last),
          when F_Payload =>
             Field_First_Payload (Cursors, First, Verified_Last, Written_Last))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, Fld),
     Post =>
       True;

   pragma Warnings (On, "formal parameter ""*"" is not referenced");

   pragma Warnings (On, "no recursive call visible");

   pragma Warnings (On, "unused variable ""*""");

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (Off, """Buffer"" is not modified, could be of access constant type");

   pragma Warnings (Off, "postcondition does not mention function result");

   function Valid_Context (Buffer_First, Buffer_Last : RFLX_Types.Index; First : RFLX_Types.Bit_Index; Last : RFLX_Types.Bit_Length; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Buffer : RFLX_Types.Bytes_Ptr; Cursors : Field_Cursors) return Boolean is
     ((if
          Buffer /= null
       then
          Buffer'Length > 0
          and Buffer'First = Buffer_First
          and Buffer'Last = Buffer_Last)
      and then (RFLX_Types.To_Index (First) >= Buffer_First
                and RFLX_Types.To_Index (Last) <= Buffer_Last
                and Buffer_Last < RFLX_Types.Index'Last
                and First <= Last + 1
                and Last < RFLX_Types.Bit_Index'Last
                and First rem RFLX_Types.Byte'Size = 1
                and Last rem RFLX_Types.Byte'Size = 0)
      and then First - 1 <= Verified_Last
      and then First - 1 <= Written_Last
      and then Verified_Last <= Written_Last
      and then Written_Last <= Last
      and then First rem RFLX_Types.Byte'Size = 1
      and then Last rem RFLX_Types.Byte'Size = 0
      and then Verified_Last rem RFLX_Types.Byte'Size = 0
      and then Written_Last rem RFLX_Types.Byte'Size = 0
      and then Cursors_Invariant (Cursors, First, Verified_Last)
      and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
      and then ((if
                    Well_Formed (Cursors (F_Packet_Type))
                 then
                    (Cursors (F_Packet_Type).Last - Cursors (F_Packet_Type).First + 1 = 4
                     and then Cursors (F_Packet_Type).First = First))
                and then (if
                             Well_Formed (Cursors (F_DUP))
                          then
                             (Cursors (F_DUP).Last - Cursors (F_DUP).First + 1 = 1
                              and then Cursors (F_DUP).First = Cursors (F_Packet_Type).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_QoS))
                          then
                             (Cursors (F_QoS).Last - Cursors (F_QoS).First + 1 = 2
                              and then Cursors (F_QoS).First = Cursors (F_DUP).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Retain))
                          then
                             (Cursors (F_Retain).Last - Cursors (F_Retain).First + 1 = 1
                              and then Cursors (F_Retain).First = Cursors (F_QoS).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Remaining_Length))
                          then
                             (Cursors (F_Remaining_Length).Last - Cursors (F_Remaining_Length).First + 1 = 8
                              and then Cursors (F_Remaining_Length).First = Cursors (F_Retain).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Topic_Name_Length))
                          then
                             (Cursors (F_Topic_Name_Length).Last - Cursors (F_Topic_Name_Length).First + 1 = 16
                              and then Cursors (F_Topic_Name_Length).First = Cursors (F_Remaining_Length).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Topic_Name))
                          then
                             (Cursors (F_Topic_Name).Last - Cursors (F_Topic_Name).First + 1 = RFLX_Types.Bit_Length (Cursors (F_Topic_Name_Length).Value) * 8
                              and then Cursors (F_Topic_Name).First = Cursors (F_Topic_Name_Length).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Packet_Identifier))
                          then
                             (Cursors (F_Packet_Identifier).Last - Cursors (F_Packet_Identifier).First + 1 = 16
                              and then Cursors (F_Packet_Identifier).First = Cursors (F_Topic_Name).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Payload))
                          then
                             (if
                                 Well_Formed (Cursors (F_Packet_Identifier))
                                 and then True
                              then
                                 Cursors (F_Payload).Last - Cursors (F_Payload).First + 1 = RFLX_Types.Bit_Length (Cursors (F_Remaining_Length).Value) * 8 + RFLX_Types.Bit_Length (Cursors (F_Topic_Name_Length).Value) * (-8) - 32
                                 and then Cursors (F_Payload).First = Cursors (F_Packet_Identifier).Last + 1)
                             and then (if
                                          Well_Formed (Cursors (F_Topic_Name))
                                          and then (RFLX_Types.Base_Integer (Cursors (F_QoS).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.QOS_0))
                                                    and then RFLX_Types.Base_Integer (Cursors (F_Remaining_Length).Value) >= RFLX_Types.Base_Integer (Cursors (F_Topic_Name_Length).Value) + 2)
                                       then
                                          Cursors (F_Payload).Last - Cursors (F_Payload).First + 1 = RFLX_Types.Bit_Length (Cursors (F_Remaining_Length).Value) * 8 + RFLX_Types.Bit_Length (Cursors (F_Topic_Name_Length).Value) * (-8) - 16
                                          and then Cursors (F_Payload).First = Cursors (F_Topic_Name).Last + 1))))
   with
     Post =>
       True;

   pragma Warnings (On, """Buffer"" is not modified, could be of access constant type");

   pragma Warnings (On, "postcondition does not mention function result");

   type Context (Buffer_First, Buffer_Last : RFLX_Types.Index := RFLX_Types.Index'First; First : RFLX_Types.Bit_Index := RFLX_Types.Bit_Index'First; Last : RFLX_Types.Bit_Length := RFLX_Types.Bit_Length'First) is
      record
         Verified_Last : RFLX_Types.Bit_Length := First - 1;
         Written_Last : RFLX_Types.Bit_Length := First - 1;
         Buffer : RFLX_Types.Bytes_Ptr := null;
         Cursors : Field_Cursors := (others => <>);
      end record
   with
     Dynamic_Predicate =>
       Valid_Context (Context.Buffer_First, Context.Buffer_Last, Context.First, Context.Last, Context.Verified_Last, Context.Written_Last, Context.Buffer, Context.Cursors);

   function Initialized (Ctx : Context) return Boolean is
     (Ctx.Verified_Last = Ctx.First - 1
      and then Valid_Next (Ctx, F_Packet_Type)
      and then RFLX.Publish.Packet.Field_First (Ctx, RFLX.Publish.Packet.F_Packet_Type) rem RFLX_Types.Byte'Size = 1
      and then Available_Space (Ctx, F_Packet_Type) = Ctx.Last - Ctx.First + 1
      and then (for all F in Field =>
                   Invalid (Ctx, F)));

   function Read (Ctx : Context) return RFLX_Types.Bytes is
     (Ctx.Buffer.all (RFLX_Types.To_Index (Ctx.First) .. RFLX_Types.To_Index (Ctx.Verified_Last)));

   function Has_Buffer (Ctx : Context) return Boolean is
     (Ctx.Buffer /= null);

   function Buffer_Length (Ctx : Context) return RFLX_Types.Length is
     (Ctx.Buffer'Length);

   function Buffer_Size (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Buffer'Length * RFLX_Types.Byte'Size);

   function Size (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Verified_Last - Ctx.First + 1);

   function Byte_Size (Ctx : Context) return RFLX_Types.Length is
     (RFLX_Types.To_Length (Size (Ctx)));

   function Message_Last (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Verified_Last);

   function Written_Last (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Written_Last);

   function Valid_Value (Fld : Field; Val : RFLX_Types.Base_Integer) return Boolean is
     (case Fld is
          when F_Packet_Type =>
             RFLX.Control_Packet.Valid_Packet_Type (Val),
          when F_DUP =>
             Valid_Boolean (Val),
          when F_QoS =>
             RFLX.Control_Packet.Valid_QoS_Level (Val),
          when F_Retain =>
             RFLX.Publish.Valid_Retain_Deferred (Val),
          when F_Remaining_Length =>
             RFLX.Publish.Valid_Remaining_Length (Val),
          when F_Topic_Name_Length =>
             RFLX.Control_Packet.Valid_String_Length (Val),
          when F_Topic_Name =>
             True,
          when F_Packet_Identifier =>
             RFLX.Control_Packet.Valid_Packet_Identifier (Val),
          when F_Payload =>
             True);

   function Field_Condition (Ctx : Context; Fld : Field; Val : RFLX_Types.Base_Integer) return Boolean is
     (case Fld is
          when F_Packet_Type =>
             Val = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.PUBLISH)),
          when F_DUP | F_QoS | F_Retain | F_Remaining_Length | F_Topic_Name_Length =>
             True,
          when F_Topic_Name =>
             ((RFLX_Types.Base_Integer (Ctx.Cursors (F_QoS).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.QOS_1))
               or else RFLX_Types.Base_Integer (Ctx.Cursors (F_QoS).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.QOS_2)))
              and then RFLX_Types.Base_Integer (Ctx.Cursors (F_Remaining_Length).Value) >= RFLX_Types.Base_Integer (Ctx.Cursors (F_Topic_Name_Length).Value) + 4)
             or else (RFLX_Types.Base_Integer (Ctx.Cursors (F_QoS).Value) = RFLX_Types.Base_Integer (To_Base_Integer (RFLX.Control_Packet.QOS_0))
                      and then RFLX_Types.Base_Integer (Ctx.Cursors (F_Remaining_Length).Value) >= RFLX_Types.Base_Integer (Ctx.Cursors (F_Topic_Name_Length).Value) + 2),
          when F_Packet_Identifier | F_Payload =>
             True);

   function Field_Size (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Length is
     (Field_Size_Internal (Ctx.Cursors, Ctx.First, Ctx.Verified_Last, Ctx.Written_Last, Fld));

   function Field_First (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Index is
     (Field_First_Internal (Ctx.Cursors, Ctx.First, Ctx.Verified_Last, Ctx.Written_Last, Fld));

   function Field_Last (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Length is
     (Field_First (Ctx, Fld) + Field_Size (Ctx, Fld) - 1);

   function Valid_Next (Ctx : Context; Fld : Field) return Boolean is
     (Valid_Next_Internal (Ctx.Cursors, Ctx.First, Ctx.Verified_Last, Ctx.Written_Last, Fld));

   function Available_Space (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Length is
     (Ctx.Last - Field_First (Ctx, Fld) + 1);

   function Sufficient_Space (Ctx : Context; Fld : Field) return Boolean is
     (Available_Space (Ctx, Fld) >= Field_Size (Ctx, Fld));

   function Present (Ctx : Context; Fld : Field) return Boolean is
     (Well_Formed (Ctx.Cursors (Fld))
      and then Ctx.Cursors (Fld).First < Ctx.Cursors (Fld).Last + 1);

   function Well_Formed (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Valid
      or Ctx.Cursors (Fld).State = S_Well_Formed);

   function Valid (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Valid
      and then Ctx.Cursors (Fld).First < Ctx.Cursors (Fld).Last + 1);

   function Incomplete (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Incomplete);

   function Invalid (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Invalid
      or Ctx.Cursors (Fld).State = S_Incomplete);

   function Well_Formed_Message (Ctx : Context) return Boolean is
     (Well_Formed (Ctx, F_Payload));

   function Valid_Message (Ctx : Context) return Boolean is
     (Valid (Ctx, F_Payload));

   function Incomplete_Message (Ctx : Context) return Boolean is
     ((for some F in Field =>
          Incomplete (Ctx, F)));

   function Get_Packet_Type (Ctx : Context) return RFLX.Control_Packet.Packet_Type is
     (To_Actual (Ctx.Cursors (F_Packet_Type).Value));

   function Get_DUP (Ctx : Context) return Boolean is
     (To_Actual (Ctx.Cursors (F_DUP).Value));

   function Get_QoS (Ctx : Context) return RFLX.Control_Packet.QoS_Level is
     (To_Actual (Ctx.Cursors (F_QoS).Value));

   function Get_Retain (Ctx : Context) return RFLX.Publish.Retain_Deferred is
     (To_Actual (Ctx.Cursors (F_Retain).Value));

   function Get_Remaining_Length (Ctx : Context) return RFLX.Publish.Remaining_Length is
     (To_Actual (Ctx.Cursors (F_Remaining_Length).Value));

   function Get_Topic_Name_Length (Ctx : Context) return RFLX.Control_Packet.String_Length is
     (To_Actual (Ctx.Cursors (F_Topic_Name_Length).Value));

   function Get_Packet_Identifier (Ctx : Context) return RFLX.Control_Packet.Packet_Identifier is
     (To_Actual (Ctx.Cursors (F_Packet_Identifier).Value));

   function Valid_Size (Ctx : Context; Fld : Field; Size : RFLX_Types.Bit_Length) return Boolean is
     (Size = Field_Size (Ctx, Fld))
   with
     Pre =>
       RFLX.Publish.Packet.Valid_Next (Ctx, Fld);

   function Valid_Length (Ctx : Context; Fld : Field; Length : RFLX_Types.Length) return Boolean is
     (Valid_Size (Ctx, Fld, RFLX_Types.To_Bit_Length (Length)));

   function Context_Cursor (Ctx : Context; Fld : Field) return Field_Cursor is
     (Ctx.Cursors (Fld));

   function Context_Cursors (Ctx : Context) return Field_Cursors is
     (Ctx.Cursors);

   function Context_Cursors_Index (Cursors : Field_Cursors; Fld : Field) return Field_Cursor is
     (Cursors (Fld));

end RFLX.Publish.Packet;
