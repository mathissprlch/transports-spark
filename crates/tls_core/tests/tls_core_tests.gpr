with "tls_core.gpr";
with "rflx_runtime.gpr";

project Tls_Core_Tests is

   for Source_Dirs use ("src");
   for Object_Dir use "obj";
   for Exec_Dir use "bin";
   for Create_Missing_Dirs use "True";
   for Main use ("tls_core_tests.adb", "tls_perf_bench.adb");

   package Compiler is
      --  -gnata removed: see tls_core.gpr for rationale (abstract
      --  Spec_X ghost functions can't be runtime-evaluated).
      for Default_Switches ("Ada") use
        ("-g", "-O2", "-gnat2022", "-gnatwae", "-gnatVa", "-gnatyM100");
      --  Note: -O2 here so the bench numbers are realistic. The
      --  test binary uses the same switches; performance figures
      --  reported are -O2, not -O0.
   end Compiler;

end Tls_Core_Tests;
