      Buffer_First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Extensions));
      Buffer_Last : constant RFLX_Types.Index := Buffer_First + Data'Length - 1;
   begin
      Initialize_Extensions_Private (Ctx, Data'Length);
      pragma Assert (Buffer_Last = RFLX_Types.To_Index (Field_Last (Ctx, F_Extensions)));
      Ctx.Buffer.all (Buffer_First .. Buffer_Last) := Data;
      pragma Assert (Ctx.Buffer.all (RFLX_Types.To_Index (Field_First (Ctx, F_Extensions)) .. RFLX_Types.To_Index (Field_Last (Ctx, F_Extensions))) = Data);
   end Set_Extensions;

   procedure Generic_Set_Ticket_Nonce (Ctx : in out Context; Length : RFLX_Types.Length) is
      First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Ticket_Nonce));
   begin
      if Length > 0 then
         Process_Ticket_Nonce (Ctx.Buffer.all (First .. First + RFLX_Types.Index (Length) - 1));
      end if;
      pragma Assert (RFLX.New_Session_Ticket.Message.Valid_Length (Ctx, RFLX.New_Session_Ticket.Message.F_Ticket_Nonce, Length));
      Initialize_Ticket_Nonce_Private (Ctx, Length);
   end Generic_Set_Ticket_Nonce;

   procedure Generic_Set_Ticket (Ctx : in out Context; Length : RFLX_Types.Length) is
      First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Ticket));
   begin
      if Length > 0 then
         Process_Ticket (Ctx.Buffer.all (First .. First + RFLX_Types.Index (Length) - 1));
      end if;
      pragma Assert (RFLX.New_Session_Ticket.Message.Valid_Length (Ctx, RFLX.New_Session_Ticket.Message.F_Ticket, Length));
      Initialize_Ticket_Private (Ctx, Length);
   end Generic_Set_Ticket;

   procedure Generic_Set_Extensions (Ctx : in out Context; Length : RFLX_Types.Length) is
      First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Extensions));
   begin
      if Length > 0 then
         Process_Extensions (Ctx.Buffer.all (First .. First + RFLX_Types.Index (Length) - 1));
      end if;
      pragma Assert (RFLX.New_Session_Ticket.Message.Valid_Length (Ctx, RFLX.New_Session_Ticket.Message.F_Extensions, Length));
      Initialize_Extensions_Private (Ctx, Length);
   end Generic_Set_Extensions;

   procedure To_Structure (Ctx : Context; Struct : out Structure) is
   begin
      Struct.Ticket_Lifetime := Get_Ticket_Lifetime (Ctx);
      Struct.Ticket_Age_Add := Get_Ticket_Age_Add (Ctx);
      Struct.Nonce_Len := Get_Nonce_Len (Ctx);
      Struct.Ticket_Nonce := (others => 0);
      Get_Ticket_Nonce (Ctx, Struct.Ticket_Nonce (Struct.Ticket_Nonce'First .. Struct.Ticket_Nonce'First + RFLX_Types.Index (RFLX_Types.To_Length (Field_Size (Ctx, F_Ticket_Nonce)) + 1) - 2));
      Struct.Ticket_Len := Get_Ticket_Len (Ctx);
      Struct.Ticket := (others => 0);
      Get_Ticket (Ctx, Struct.Ticket (Struct.Ticket'First .. Struct.Ticket'First + RFLX_Types.Index (RFLX_Types.To_Length (Field_Size (Ctx, F_Ticket)) + 1) - 2));
      Struct.Extensions_Len := Get_Extensions_Len (Ctx);
      Struct.Extensions := (others => 0);
      Get_Extensions (Ctx, Struct.Extensions (Struct.Extensions'First .. Struct.Extensions'First + RFLX_Types.Index (RFLX_Types.To_Length (Field_Size (Ctx, F_Extensions)) + 1) - 2));
   end To_Structure;

   procedure To_Context (Struct : Structure; Ctx : in out Context) is
   begin
      Reset (Ctx);
      Set_Ticket_Lifetime (Ctx, Struct.Ticket_Lifetime);
      Set_Ticket_Age_Add (Ctx, Struct.Ticket_Age_Add);
      Set_Nonce_Len (Ctx, Struct.Nonce_Len);
      Set_Ticket_Nonce (Ctx, Struct.Ticket_Nonce (Struct.Ticket_Nonce'First .. Struct.Ticket_Nonce'First + RFLX_Types.Index (RFLX_Types.To_Length (RFLX_Types.Bit_Length (Struct.Nonce_Len) * 8) + 1) - 2));
      Set_Ticket_Len (Ctx, Struct.Ticket_Len);
      Set_Ticket (Ctx, Struct.Ticket (Struct.Ticket'First .. Struct.Ticket'First + RFLX_Types.Index (RFLX_Types.To_Length (RFLX_Types.Bit_Length (Struct.Ticket_Len) * 8) + 1) - 2));
      Set_Extensions_Len (Ctx, Struct.Extensions_Len);
      Set_Extensions (Ctx, Struct.Extensions (Struct.Extensions'First .. Struct.Extensions'First + RFLX_Types.Index (RFLX_Types.To_Length (RFLX_Types.Bit_Length (Struct.Extensions_Len) * 8) + 1) - 2));
   end To_Context;

end RFLX.New_Session_Ticket.Message;
