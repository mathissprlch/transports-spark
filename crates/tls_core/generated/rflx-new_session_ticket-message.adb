   procedure Initialize_Extensions (Ctx : in out Context) is
   begin
      Initialize_Extensions_Private (Ctx, RFLX_Types.To_Length (Field_Size (Ctx, F_Extensions)));
   end Initialize_Extensions;

   procedure Set_Ticket_Nonce (Ctx : in out Context; Data : RFLX_Types.Bytes) is
      Buffer_First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Ticket_Nonce));
      Buffer_Last : constant RFLX_Types.Index := Buffer_First + Data'Length - 1;
   begin
      Initialize_Ticket_Nonce_Private (Ctx, Data'Length);
      pragma Assert (Buffer_Last = RFLX_Types.To_Index (Field_Last (Ctx, F_Ticket_Nonce)));
      Ctx.Buffer.all (Buffer_First .. Buffer_Last) := Data;
      pragma Assert (Ctx.Buffer.all (RFLX_Types.To_Index (Field_First (Ctx, F_Ticket_Nonce)) .. RFLX_Types.To_Index (Field_Last (Ctx, F_Ticket_Nonce))) = Data);
   end Set_Ticket_Nonce;

   procedure Set_Ticket (Ctx : in out Context; Data : RFLX_Types.Bytes) is
      Buffer_First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Ticket));
      Buffer_Last : constant RFLX_Types.Index := Buffer_First + Data'Length - 1;
   begin
      Initialize_Ticket_Private (Ctx, Data'Length);
      pragma Assert (Buffer_Last = RFLX_Types.To_Index (Field_Last (Ctx, F_Ticket)));
      Ctx.Buffer.all (Buffer_First .. Buffer_Last) := Data;
      pragma Assert (Ctx.Buffer.all (RFLX_Types.To_Index (Field_First (Ctx, F_Ticket)) .. RFLX_Types.To_Index (Field_Last (Ctx, F_Ticket))) = Data);
   end Set_Ticket;

