       and then (Ctx.Cursors (Fld).Value = Val
                 and then (if
                              Fld in F_Extensions
                              and then Well_Formed_Message (Ctx)
                           then
                              Message_Last (Ctx) = Field_Last (Ctx, Fld)))
       and then (for all F in Field =>
