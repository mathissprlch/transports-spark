       and then Get_Ticket_Age_Add (Ctx) = Get_Ticket_Age_Add (Ctx)'Old
       and then Get_Nonce_Len (Ctx) = Get_Nonce_Len (Ctx)'Old
       and then Field_First (Ctx, F_Ticket_Nonce) = Field_First (Ctx, F_Ticket_Nonce)'Old
   is
      First : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Ticket_Nonce);
      Last : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Ticket_Nonce) + RFLX_Types.Bit_Length (Length) * RFLX_Types.Byte'Size - 1;
   begin
      pragma Assert (Last mod RFLX_Types.Byte'Size = 0);
      Reset_Dependent_Fields (Ctx, F_Ticket_Nonce);
      pragma Warnings (Off, "attribute Update is an obsolescent feature");
      Ctx := Ctx'Update (Verified_Last => Last, Written_Last => Last);
      pragma Warnings (On, "attribute Update is an obsolescent feature");
      Ctx.Cursors (F_Ticket_Nonce) := (State => S_Well_Formed, First => First, Last => Last, Value => 0);
   end Initialize_Ticket_Nonce_Private;

   procedure Initialize_Ticket_Nonce (Ctx : in out Context) is
   begin
      Initialize_Ticket_Nonce_Private (Ctx, RFLX_Types.To_Length (Field_Size (Ctx, F_Ticket_Nonce)));
   end Initialize_Ticket_Nonce;

   procedure Initialize_Ticket_Private (Ctx : in out Context; Length : RFLX_Types.Length)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.New_Session_Ticket.Message.Has_Buffer (Ctx)
       and then RFLX.New_Session_Ticket.Message.Valid_Next (Ctx, RFLX.New_Session_Ticket.Message.F_Ticket)
       and then RFLX.New_Session_Ticket.Message.Valid_Length (Ctx, RFLX.New_Session_Ticket.Message.F_Ticket, Length)
       and then RFLX_Types.To_Length (RFLX.New_Session_Ticket.Message.Available_Space (Ctx, RFLX.New_Session_Ticket.Message.F_Ticket)) >= Length,
     Post =>
       Has_Buffer (Ctx)
       and then Well_Formed (Ctx, F_Ticket)
       and then Field_Size (Ctx, F_Ticket) = RFLX_Types.To_Bit_Length (Length)
       and then Ctx.Verified_Last = Field_Last (Ctx, F_Ticket)
       and then Invalid (Ctx, F_Extensions_Len)
       and then Invalid (Ctx, F_Extensions)
       and then Valid_Next (Ctx, F_Extensions_Len)
       and then Ctx.Buffer_First = Ctx.Buffer_First'Old
       and then Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and then Ctx.First = Ctx.First'Old
       and then Ctx.Last = Ctx.Last'Old
       and then Valid_Next (Ctx, F_Ticket) = Valid_Next (Ctx, F_Ticket)'Old
       and then Get_Ticket_Lifetime (Ctx) = Get_Ticket_Lifetime (Ctx)'Old
       and then Get_Ticket_Age_Add (Ctx) = Get_Ticket_Age_Add (Ctx)'Old
       and then Get_Nonce_Len (Ctx) = Get_Nonce_Len (Ctx)'Old
       and then Get_Ticket_Len (Ctx) = Get_Ticket_Len (Ctx)'Old
       and then Field_First (Ctx, F_Ticket) = Field_First (Ctx, F_Ticket)'Old
   is
      First : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Ticket);
      Last : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Ticket) + RFLX_Types.Bit_Length (Length) * RFLX_Types.Byte'Size - 1;
   begin
      pragma Assert (Last mod RFLX_Types.Byte'Size = 0);
      Reset_Dependent_Fields (Ctx, F_Ticket);
      pragma Warnings (Off, "attribute Update is an obsolescent feature");
      Ctx := Ctx'Update (Verified_Last => Last, Written_Last => Last);
      pragma Warnings (On, "attribute Update is an obsolescent feature");
      Ctx.Cursors (F_Ticket) := (State => S_Well_Formed, First => First, Last => Last, Value => 0);
   end Initialize_Ticket_Private;

   procedure Initialize_Ticket (Ctx : in out Context) is
   begin
      Initialize_Ticket_Private (Ctx, RFLX_Types.To_Length (Field_Size (Ctx, F_Ticket)));
   end Initialize_Ticket;

   procedure Initialize_Extensions_Private (Ctx : in out Context; Length : RFLX_Types.Length)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.New_Session_Ticket.Message.Has_Buffer (Ctx)
       and then RFLX.New_Session_Ticket.Message.Valid_Next (Ctx, RFLX.New_Session_Ticket.Message.F_Extensions)
       and then RFLX.New_Session_Ticket.Message.Valid_Length (Ctx, RFLX.New_Session_Ticket.Message.F_Extensions, Length)
       and then RFLX_Types.To_Length (RFLX.New_Session_Ticket.Message.Available_Space (Ctx, RFLX.New_Session_Ticket.Message.F_Extensions)) >= Length,
     Post =>
       Has_Buffer (Ctx)
       and then Well_Formed (Ctx, F_Extensions)
       and then Field_Size (Ctx, F_Extensions) = RFLX_Types.To_Bit_Length (Length)
       and then Ctx.Verified_Last = Field_Last (Ctx, F_Extensions)
       and then Ctx.Buffer_First = Ctx.Buffer_First'Old
       and then Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and then Ctx.First = Ctx.First'Old
       and then Ctx.Last = Ctx.Last'Old
       and then Valid_Next (Ctx, F_Extensions) = Valid_Next (Ctx, F_Extensions)'Old
       and then Get_Ticket_Lifetime (Ctx) = Get_Ticket_Lifetime (Ctx)'Old
       and then Get_Ticket_Age_Add (Ctx) = Get_Ticket_Age_Add (Ctx)'Old
       and then Get_Nonce_Len (Ctx) = Get_Nonce_Len (Ctx)'Old
       and then Get_Ticket_Len (Ctx) = Get_Ticket_Len (Ctx)'Old
       and then Get_Extensions_Len (Ctx) = Get_Extensions_Len (Ctx)'Old
       and then Field_First (Ctx, F_Extensions) = Field_First (Ctx, F_Extensions)'Old
   is
      First : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Extensions);
      Last : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Extensions) + RFLX_Types.Bit_Length (Length) * RFLX_Types.Byte'Size - 1;
   begin
      pragma Assert (Last mod RFLX_Types.Byte'Size = 0);
      Reset_Dependent_Fields (Ctx, F_Extensions);
      pragma Warnings (Off, "attribute Update is an obsolescent feature");
      Ctx := Ctx'Update (Verified_Last => Last, Written_Last => Last);
      pragma Warnings (On, "attribute Update is an obsolescent feature");
