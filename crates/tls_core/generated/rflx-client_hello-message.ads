       and then RFLX.Client_Hello.Message.Valid_Next (Ctx, RFLX.Client_Hello.Message.F_Compression_Methods)
       and then RFLX.Client_Hello.Message.Available_Space (Ctx, RFLX.Client_Hello.Message.F_Compression_Methods) >= RFLX.Client_Hello.Message.Field_Size (Ctx, RFLX.Client_Hello.Message.F_Compression_Methods)
       and then RFLX.Client_Hello.Message.Valid_Length (Ctx, RFLX.Client_Hello.Message.F_Compression_Methods, Data'Length)
       and then RFLX.Client_Hello.Message.Available_Space (Ctx, RFLX.Client_Hello.Message.F_Compression_Methods) >= Data'Length * RFLX_Types.Byte'Size
       and then RFLX.Client_Hello.Message.Field_Condition (Ctx, RFLX.Client_Hello.Message.F_Compression_Methods),
     Post =>
       Has_Buffer (Ctx)
       and Well_Formed (Ctx, F_Compression_Methods)
       and Invalid (Ctx, F_Extensions_Len)
       and Invalid (Ctx, F_Extensions)
       and Valid_Next (Ctx, F_Extensions_Len)
       and Ctx.Buffer_First = Ctx.Buffer_First'Old
       and Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and Ctx.First = Ctx.First'Old
       and Ctx.Last = Ctx.Last'Old
       and Valid_Next (Ctx, F_Compression_Methods) = Valid_Next (Ctx, F_Compression_Methods)'Old
       and Get_Session_Id_Len (Ctx) = Get_Session_Id_Len (Ctx)'Old
       and Get_Suites_Len (Ctx) = Get_Suites_Len (Ctx)'Old
       and Get_Compression_Len (Ctx) = Get_Compression_Len (Ctx)'Old
       and Field_First (Ctx, F_Compression_Methods) = Field_First (Ctx, F_Compression_Methods)'Old
       and Equal (Ctx, F_Compression_Methods, Data);

   generic
      with procedure Process_Random (Random : out RFLX_Types.Bytes);
      with function Process_Data_Pre (Length : RFLX_Types.Length) return Boolean;
   procedure Generic_Set_Random (Ctx : in out Context; Length : RFLX_Types.Length)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.Client_Hello.Message.Has_Buffer (Ctx)
       and then RFLX.Client_Hello.Message.Valid_Next (Ctx, RFLX.Client_Hello.Message.F_Random)
       and then RFLX.Client_Hello.Message.Available_Space (Ctx, RFLX.Client_Hello.Message.F_Random) >= RFLX.Client_Hello.Message.Field_Size (Ctx, RFLX.Client_Hello.Message.F_Random)
       and then RFLX.Client_Hello.Message.Valid_Length (Ctx, RFLX.Client_Hello.Message.F_Random, Length)
       and then RFLX_Types.To_Length (RFLX.Client_Hello.Message.Available_Space (Ctx, RFLX.Client_Hello.Message.F_Random)) >= Length
       and then Process_Data_Pre (Length),
     Post =>
       Has_Buffer (Ctx)
       and Well_Formed (Ctx, F_Random)
       and Invalid (Ctx, F_Session_Id_Len)
       and Invalid (Ctx, F_Session_Id)
       and Invalid (Ctx, F_Suites_Len)
       and Invalid (Ctx, F_Cipher_Suites)
       and Invalid (Ctx, F_Compression_Len)
       and Invalid (Ctx, F_Compression_Methods)
       and Invalid (Ctx, F_Extensions_Len)
       and Invalid (Ctx, F_Extensions)
       and Valid_Next (Ctx, F_Session_Id_Len)
       and Ctx.Buffer_First = Ctx.Buffer_First'Old
       and Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and Ctx.First = Ctx.First'Old
       and Ctx.Last = Ctx.Last'Old
       and Valid_Next (Ctx, F_Random) = Valid_Next (Ctx, F_Random)'Old
       and Field_First (Ctx, F_Random) = Field_First (Ctx, F_Random)'Old;

   generic
      with procedure Process_Session_Id (Session_Id : out RFLX_Types.Bytes);
      with function Process_Data_Pre (Length : RFLX_Types.Length) return Boolean;
   procedure Generic_Set_Session_Id (Ctx : in out Context; Length : RFLX_Types.Length)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.Client_Hello.Message.Has_Buffer (Ctx)
       and then RFLX.Client_Hello.Message.Valid_Next (Ctx, RFLX.Client_Hello.Message.F_Session_Id)
       and then RFLX.Client_Hello.Message.Available_Space (Ctx, RFLX.Client_Hello.Message.F_Session_Id) >= RFLX.Client_Hello.Message.Field_Size (Ctx, RFLX.Client_Hello.Message.F_Session_Id)
       and then RFLX.Client_Hello.Message.Valid_Length (Ctx, RFLX.Client_Hello.Message.F_Session_Id, Length)
       and then RFLX_Types.To_Length (RFLX.Client_Hello.Message.Available_Space (Ctx, RFLX.Client_Hello.Message.F_Session_Id)) >= Length
       and then Process_Data_Pre (Length),
     Post =>
       Has_Buffer (Ctx)
       and Well_Formed (Ctx, F_Session_Id)
       and Invalid (Ctx, F_Suites_Len)
       and Invalid (Ctx, F_Cipher_Suites)
       and Invalid (Ctx, F_Compression_Len)
       and Invalid (Ctx, F_Compression_Methods)
       and Invalid (Ctx, F_Extensions_Len)
       and Invalid (Ctx, F_Extensions)
       and Valid_Next (Ctx, F_Suites_Len)
       and Ctx.Buffer_First = Ctx.Buffer_First'Old
       and Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and Ctx.First = Ctx.First'Old
       and Ctx.Last = Ctx.Last'Old
       and Valid_Next (Ctx, F_Session_Id) = Valid_Next (Ctx, F_Session_Id)'Old
       and Get_Session_Id_Len (Ctx) = Get_Session_Id_Len (Ctx)'Old
       and Field_First (Ctx, F_Session_Id) = Field_First (Ctx, F_Session_Id)'Old;

   generic
      with procedure Process_Cipher_Suites (Cipher_Suites : out RFLX_Types.Bytes);
      with function Process_Data_Pre (Length : RFLX_Types.Length) return Boolean;
   procedure Generic_Set_Cipher_Suites (Ctx : in out Context; Length : RFLX_Types.Length)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.Client_Hello.Message.Has_Buffer (Ctx)
       and then RFLX.Client_Hello.Message.Valid_Next (Ctx, RFLX.Client_Hello.Message.F_Cipher_Suites)
       and then RFLX.Client_Hello.Message.Available_Space (Ctx, RFLX.Client_Hello.Message.F_Cipher_Suites) >= RFLX.Client_Hello.Message.Field_Size (Ctx, RFLX.Client_Hello.Message.F_Cipher_Suites)
       and then RFLX.Client_Hello.Message.Valid_Length (Ctx, RFLX.Client_Hello.Message.F_Cipher_Suites, Length)
       and then RFLX_Types.To_Length (RFLX.Client_Hello.Message.Available_Space (Ctx, RFLX.Client_Hello.Message.F_Cipher_Suites)) >= Length
       and then Process_Data_Pre (Length),
     Post =>
       Has_Buffer (Ctx)
       and Well_Formed (Ctx, F_Cipher_Suites)
       and Invalid (Ctx, F_Compression_Len)
       and Invalid (Ctx, F_Compression_Methods)
       and Invalid (Ctx, F_Extensions_Len)
       and Invalid (Ctx, F_Extensions)
       and Valid_Next (Ctx, F_Compression_Len)
       and Ctx.Buffer_First = Ctx.Buffer_First'Old
       and Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and Ctx.First = Ctx.First'Old
       and Ctx.Last = Ctx.Last'Old
       and Valid_Next (Ctx, F_Cipher_Suites) = Valid_Next (Ctx, F_Cipher_Suites)'Old
       and Get_Session_Id_Len (Ctx) = Get_Session_Id_Len (Ctx)'Old
       and Get_Suites_Len (Ctx) = Get_Suites_Len (Ctx)'Old
       and Field_First (Ctx, F_Cipher_Suites) = Field_First (Ctx, F_Cipher_Suites)'Old;

   generic
      with procedure Process_Compression_Methods (Compression_Methods : out RFLX_Types.Bytes);
      with function Process_Data_Pre (Length : RFLX_Types.Length) return Boolean;
   procedure Generic_Set_Compression_Methods (Ctx : in out Context; Length : RFLX_Types.Length)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.Client_Hello.Message.Has_Buffer (Ctx)
       and then RFLX.Client_Hello.Message.Valid_Next (Ctx, RFLX.Client_Hello.Message.F_Compression_Methods)
       and then RFLX.Client_Hello.Message.Available_Space (Ctx, RFLX.Client_Hello.Message.F_Compression_Methods) >= RFLX.Client_Hello.Message.Field_Size (Ctx, RFLX.Client_Hello.Message.F_Compression_Methods)
       and then RFLX.Client_Hello.Message.Valid_Length (Ctx, RFLX.Client_Hello.Message.F_Compression_Methods, Length)
       and then RFLX_Types.To_Length (RFLX.Client_Hello.Message.Available_Space (Ctx, RFLX.Client_Hello.Message.F_Compression_Methods)) >= Length
       and then Process_Data_Pre (Length),
     Post =>
       Has_Buffer (Ctx)
       and Well_Formed (Ctx, F_Compression_Methods)
       and Invalid (Ctx, F_Extensions_Len)
       and Invalid (Ctx, F_Extensions)
       and Valid_Next (Ctx, F_Extensions_Len)
       and Ctx.Buffer_First = Ctx.Buffer_First'Old
       and Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and Ctx.First = Ctx.First'Old
       and Ctx.Last = Ctx.Last'Old
       and Valid_Next (Ctx, F_Compression_Methods) = Valid_Next (Ctx, F_Compression_Methods)'Old
       and Get_Session_Id_Len (Ctx) = Get_Session_Id_Len (Ctx)'Old
       and Get_Suites_Len (Ctx) = Get_Suites_Len (Ctx)'Old
       and Get_Compression_Len (Ctx) = Get_Compression_Len (Ctx)'Old
       and Field_First (Ctx, F_Compression_Methods) = Field_First (Ctx, F_Compression_Methods)'Old;

   procedure Switch_To_Extensions (Ctx : in out Context; Seq_Ctx : out RFLX.TLS_Extensions.Extension_List.Context)
   with
     Pre =>
       not Ctx'Constrained
       and then not Seq_Ctx'Constrained
       and then RFLX.Client_Hello.Message.Has_Buffer (Ctx)
       and then RFLX.Client_Hello.Message.Valid_Next (Ctx, RFLX.Client_Hello.Message.F_Extensions)
       and then RFLX.Client_Hello.Message.Field_Size (Ctx, RFLX.Client_Hello.Message.F_Extensions) > 0
       and then RFLX.Client_Hello.Message.Field_First (Ctx, RFLX.Client_Hello.Message.F_Extensions) rem RFLX_Types.Byte'Size = 1
       and then RFLX.Client_Hello.Message.Available_Space (Ctx, RFLX.Client_Hello.Message.F_Extensions) >= RFLX.Client_Hello.Message.Field_Size (Ctx, RFLX.Client_Hello.Message.F_Extensions)
       and then RFLX.Client_Hello.Message.Field_Condition (Ctx, RFLX.Client_Hello.Message.F_Extensions),
     Post =>
       not RFLX.Client_Hello.Message.Has_Buffer (Ctx)
       and RFLX.TLS_Extensions.Extension_List.Has_Buffer (Seq_Ctx)
       and Ctx.Buffer_First = Seq_Ctx.Buffer_First
       and Ctx.Buffer_Last = Seq_Ctx.Buffer_Last
       and Seq_Ctx.First = Field_First (Ctx, F_Extensions)
       and Seq_Ctx.Last = Field_Last (Ctx, F_Extensions)
       and RFLX.TLS_Extensions.Extension_List.Valid (Seq_Ctx)
       and RFLX.TLS_Extensions.Extension_List.Sequence_Last (Seq_Ctx) = Seq_Ctx.First - 1
       and Present (Ctx, F_Extensions)
       and Ctx.Buffer_First = Ctx.Buffer_First'Old
       and Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and Ctx.First = Ctx.First'Old
       and Ctx.Last = Ctx.Last'Old
       and Field_Last (Ctx, F_Extensions) = Field_Last (Ctx, F_Extensions)'Old
       and (for all F in Field range F_Legacy_Version_Field .. F_Extensions_Len =>
               Context_Cursors_Index (Context_Cursors (Ctx), F) = Context_Cursors_Index (Context_Cursors (Ctx)'Old, F)),
     Contract_Cases =>
       (Well_Formed (Ctx, F_Extensions) =>
           True,
        others =>
           True);

   function Complete_Extensions (Ctx : Context; Seq_Ctx : RFLX.TLS_Extensions.Extension_List.Context) return Boolean
   with
     Pre =>
       RFLX.Client_Hello.Message.Valid_Next (Ctx, RFLX.Client_Hello.Message.F_Extensions);

   procedure Update_Extensions (Ctx : in out Context; Seq_Ctx : in out RFLX.TLS_Extensions.Extension_List.Context)
   with
     Pre =>
       RFLX.Client_Hello.Message.Present (Ctx, RFLX.Client_Hello.Message.F_Extensions)
       and then not RFLX.Client_Hello.Message.Has_Buffer (Ctx)
       and then RFLX.TLS_Extensions.Extension_List.Has_Buffer (Seq_Ctx)
       and then Ctx.Buffer_First = Seq_Ctx.Buffer_First
       and then Ctx.Buffer_Last = Seq_Ctx.Buffer_Last
       and then Seq_Ctx.First = Field_First (Ctx, F_Extensions)
       and then Seq_Ctx.Last = Field_Last (Ctx, F_Extensions),
     Post =>
       (if
           RFLX.Client_Hello.Message.Complete_Extensions (Ctx, Seq_Ctx)
        then
           Present (Ctx, F_Extensions)
        else
           Invalid (Ctx, F_Extensions))
       and Has_Buffer (Ctx)
       and not RFLX.TLS_Extensions.Extension_List.Has_Buffer (Seq_Ctx)
       and Ctx.Buffer_First = Ctx.Buffer_First'Old
       and Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and Ctx.First = Ctx.First'Old
       and Ctx.Last = Ctx.Last'Old
       and Seq_Ctx.First = Seq_Ctx.First'Old
       and Seq_Ctx.Last = Seq_Ctx.Last'Old
       and RFLX.TLS_Extensions.Extension_List.Valid (Seq_Ctx) = RFLX.TLS_Extensions.Extension_List.Valid (Seq_Ctx)'Old
       and RFLX.TLS_Extensions.Extension_List.Size (Seq_Ctx) = RFLX.TLS_Extensions.Extension_List.Size (Seq_Ctx)'Old
       and Field_First (Ctx, F_Extensions) = Field_First (Ctx, F_Extensions)'Old
       and Field_Size (Ctx, F_Extensions) = Field_Size (Ctx, F_Extensions)'Old
       and Context_Cursor (Ctx, F_Legacy_Version_Field) = Context_Cursor (Ctx, F_Legacy_Version_Field)'Old
       and Context_Cursor (Ctx, F_Random) = Context_Cursor (Ctx, F_Random)'Old
       and Context_Cursor (Ctx, F_Session_Id_Len) = Context_Cursor (Ctx, F_Session_Id_Len)'Old
       and Context_Cursor (Ctx, F_Session_Id) = Context_Cursor (Ctx, F_Session_Id)'Old
       and Context_Cursor (Ctx, F_Suites_Len) = Context_Cursor (Ctx, F_Suites_Len)'Old
       and Context_Cursor (Ctx, F_Cipher_Suites) = Context_Cursor (Ctx, F_Cipher_Suites)'Old
       and Context_Cursor (Ctx, F_Compression_Len) = Context_Cursor (Ctx, F_Compression_Len)'Old
       and Context_Cursor (Ctx, F_Compression_Methods) = Context_Cursor (Ctx, F_Compression_Methods)'Old
       and Context_Cursor (Ctx, F_Extensions_Len) = Context_Cursor (Ctx, F_Extensions_Len)'Old,
     Depends =>
       (Ctx => (Ctx, Seq_Ctx), Seq_Ctx => Seq_Ctx);

   function Context_Cursor (Ctx : Context; Fld : Field) return Field_Cursor
   with
     Annotate =>
       (GNATprove, Inline_For_Proof),
     Ghost;

   function Context_Cursors (Ctx : Context) return Field_Cursors
   with
     Annotate =>
       (GNATprove, Inline_For_Proof),
     Ghost;

   function Context_Cursors_Index (Cursors : Field_Cursors; Fld : Field) return Field_Cursor
   with
     Annotate =>
       (GNATprove, Inline_For_Proof),
     Ghost;

private

   type Cursor_State is (S_Valid, S_Well_Formed, S_Invalid, S_Incomplete);

   type Field_Cursor is
      record
         State : Cursor_State := S_Invalid;
         First : RFLX_Types.Bit_Index := RFLX_Types.Bit_Index'First;
         Last : RFLX_Types.Bit_Length := RFLX_Types.Bit_Length'First;
         Value : RFLX_Types.Base_Integer := 0;
      end record;

   type Field_Cursors is array (Virtual_Field) of Field_Cursor;

   function Well_Formed (Cursor : Field_Cursor) return Boolean is
     (Cursor.State = S_Valid
      or Cursor.State = S_Well_Formed);

   function Valid (Cursor : Field_Cursor) return Boolean is
     (Cursor.State = S_Valid);

   function Invalid (Cursor : Field_Cursor) return Boolean is
     (Cursor.State = S_Invalid
      or Cursor.State = S_Incomplete);

   pragma Warnings (Off, "postcondition does not mention function result");

   function Cursors_Invariant (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length) return Boolean is
     ((for all F in Field =>
          (if
              Well_Formed (Cursors (F))
           then
              Cursors (F).First >= First
              and Cursors (F).Last <= Verified_Last
              and Cursors (F).First <= Cursors (F).Last + 1
              and Valid_Value (F, Cursors (F).Value))))
   with
     Post =>
       True;

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (Off, "formal parameter ""*"" is not referenced");

   pragma Warnings (Off, "postcondition does not mention function result");

   pragma Warnings (Off, "unused variable ""*""");

   function Valid_Predecessors_Invariant (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return Boolean is
     ((if Well_Formed (Cursors (F_Legacy_Version_Field)) then True)
      and then (if Well_Formed (Cursors (F_Random)) then Valid (Cursors (F_Legacy_Version_Field)))
      and then (if Well_Formed (Cursors (F_Session_Id_Len)) then Well_Formed (Cursors (F_Random)))
      and then (if Well_Formed (Cursors (F_Session_Id)) then Valid (Cursors (F_Session_Id_Len)))
      and then (if Well_Formed (Cursors (F_Suites_Len)) then Well_Formed (Cursors (F_Session_Id)))
      and then (if Well_Formed (Cursors (F_Cipher_Suites)) then Valid (Cursors (F_Suites_Len)))
      and then (if Well_Formed (Cursors (F_Compression_Len)) then Well_Formed (Cursors (F_Cipher_Suites)))
      and then (if Well_Formed (Cursors (F_Compression_Methods)) then Valid (Cursors (F_Compression_Len)))
      and then (if Well_Formed (Cursors (F_Extensions_Len)) then Well_Formed (Cursors (F_Compression_Methods)))
      and then (if Well_Formed (Cursors (F_Extensions)) then Valid (Cursors (F_Extensions_Len))))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last),
     Post =>
       True;

   pragma Warnings (On, "unused variable ""*""");

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (On, "formal parameter ""*"" is not referenced");

   pragma Warnings (Off, "postcondition does not mention function result");

   function Valid_Next_Internal (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Fld : Field) return Boolean is
     (case Fld is
          when F_Legacy_Version_Field =>
             True,
          when F_Random =>
             (Valid (Cursors (F_Legacy_Version_Field))
              and then True),
          when F_Session_Id_Len =>
             (Well_Formed (Cursors (F_Random))
              and then True),
          when F_Session_Id =>
             (Valid (Cursors (F_Session_Id_Len))
              and then True),
          when F_Suites_Len =>
             (Well_Formed (Cursors (F_Session_Id))
              and then True),
          when F_Cipher_Suites =>
             (Valid (Cursors (F_Suites_Len))
              and then True),
          when F_Compression_Len =>
             (Well_Formed (Cursors (F_Cipher_Suites))
              and then True),
          when F_Compression_Methods =>
             (Valid (Cursors (F_Compression_Len))
              and then True),
          when F_Extensions_Len =>
             (Well_Formed (Cursors (F_Compression_Methods))
              and then True),
          when F_Extensions =>
             (Valid (Cursors (F_Extensions_Len))
              and then True))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last),
     Post =>
       True;

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (Off, "unused variable ""*""");

   pragma Warnings (Off, "formal parameter ""*"" is not referenced");

   function Field_Size_Internal (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Fld : Field) return RFLX_Types.Bit_Length'Base is
     (case Fld is
          when F_Legacy_Version_Field =>
             16,
          when F_Random =>
             256,
          when F_Session_Id_Len =>
             8,
          when F_Session_Id =>
             RFLX_Types.Bit_Length (Cursors (F_Session_Id_Len).Value) * 8,
          when F_Suites_Len =>
             16,
          when F_Cipher_Suites =>
             RFLX_Types.Bit_Length (Cursors (F_Suites_Len).Value) * 8,
          when F_Compression_Len =>
             8,
          when F_Compression_Methods =>
             RFLX_Types.Bit_Length (Cursors (F_Compression_Len).Value) * 8,
          when F_Extensions_Len =>
             16,
          when F_Extensions =>
             RFLX_Types.Bit_Length (Cursors (F_Extensions_Len).Value) * 8)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, Fld);

   pragma Warnings (On, "formal parameter ""*"" is not referenced");

   pragma Warnings (On, "unused variable ""*""");

   pragma Warnings (Off, "postcondition does not mention function result");

   pragma Warnings (Off, "unused variable ""*""");

   pragma Warnings (Off, "no recursive call visible");

   pragma Warnings (Off, "formal parameter ""*"" is not referenced");

   function Field_First_Legacy_Version_Field (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Legacy_Version_Field);

   function Field_First_Random (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 16)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Random);

   function Field_First_Session_Id_Len (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 272)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Session_Id_Len);

   function Field_First_Session_Id (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 280)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Session_Id);

   function Field_First_Suites_Len (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (Field_First_Session_Id (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Session_Id))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Suites_Len);

   function Field_First_Cipher_Suites (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (Field_First_Session_Id (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Session_Id) + 16)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Cipher_Suites);

   function Field_First_Compression_Len (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (Field_First_Cipher_Suites (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Cipher_Suites))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Compression_Len);

   function Field_First_Compression_Methods (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (Field_First_Cipher_Suites (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Cipher_Suites) + 8)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Compression_Methods);

   function Field_First_Extensions_Len (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (Field_First_Compression_Methods (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Compression_Methods))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Extensions_Len);

   function Field_First_Extensions (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (Field_First_Compression_Methods (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Compression_Methods) + 16)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Extensions);

   function Field_First_Internal (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Fld : Field) return RFLX_Types.Bit_Index'Base is
     (case Fld is
          when F_Legacy_Version_Field =>
             Field_First_Legacy_Version_Field (Cursors, First, Verified_Last, Written_Last),
          when F_Random =>
             Field_First_Random (Cursors, First, Verified_Last, Written_Last),
          when F_Session_Id_Len =>
             Field_First_Session_Id_Len (Cursors, First, Verified_Last, Written_Last),
          when F_Session_Id =>
             Field_First_Session_Id (Cursors, First, Verified_Last, Written_Last),
          when F_Suites_Len =>
             Field_First_Suites_Len (Cursors, First, Verified_Last, Written_Last),
          when F_Cipher_Suites =>
             Field_First_Cipher_Suites (Cursors, First, Verified_Last, Written_Last),
          when F_Compression_Len =>
             Field_First_Compression_Len (Cursors, First, Verified_Last, Written_Last),
          when F_Compression_Methods =>
             Field_First_Compression_Methods (Cursors, First, Verified_Last, Written_Last),
          when F_Extensions_Len =>
             Field_First_Extensions_Len (Cursors, First, Verified_Last, Written_Last),
          when F_Extensions =>
             Field_First_Extensions (Cursors, First, Verified_Last, Written_Last))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, Fld),
     Post =>
       True;

   pragma Warnings (On, "formal parameter ""*"" is not referenced");

   pragma Warnings (On, "no recursive call visible");

   pragma Warnings (On, "unused variable ""*""");

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (Off, """Buffer"" is not modified, could be of access constant type");

   pragma Warnings (Off, "postcondition does not mention function result");

   function Valid_Context (Buffer_First, Buffer_Last : RFLX_Types.Index; First : RFLX_Types.Bit_Index; Last : RFLX_Types.Bit_Length; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Buffer : RFLX_Types.Bytes_Ptr; Cursors : Field_Cursors) return Boolean is
     ((if
          Buffer /= null
       then
          Buffer'Length > 0
          and Buffer'First = Buffer_First
          and Buffer'Last = Buffer_Last)
      and then (RFLX_Types.To_Index (First) >= Buffer_First
                and RFLX_Types.To_Index (Last) <= Buffer_Last
                and Buffer_Last < RFLX_Types.Index'Last
                and First <= Last + 1
                and Last < RFLX_Types.Bit_Index'Last
                and First rem RFLX_Types.Byte'Size = 1
                and Last rem RFLX_Types.Byte'Size = 0)
      and then First - 1 <= Verified_Last
      and then First - 1 <= Written_Last
      and then Verified_Last <= Written_Last
      and then Written_Last <= Last
      and then First rem RFLX_Types.Byte'Size = 1
      and then Last rem RFLX_Types.Byte'Size = 0
      and then Verified_Last rem RFLX_Types.Byte'Size = 0
      and then Written_Last rem RFLX_Types.Byte'Size = 0
      and then Cursors_Invariant (Cursors, First, Verified_Last)
      and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
      and then ((if
                    Well_Formed (Cursors (F_Legacy_Version_Field))
                 then
                    (Cursors (F_Legacy_Version_Field).Last - Cursors (F_Legacy_Version_Field).First + 1 = 16
                     and then Cursors (F_Legacy_Version_Field).First = First))
                and then (if
                             Well_Formed (Cursors (F_Random))
                          then
                             (Cursors (F_Random).Last - Cursors (F_Random).First + 1 = 256
                              and then Cursors (F_Random).First = Cursors (F_Legacy_Version_Field).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Session_Id_Len))
                          then
                             (Cursors (F_Session_Id_Len).Last - Cursors (F_Session_Id_Len).First + 1 = 8
                              and then Cursors (F_Session_Id_Len).First = Cursors (F_Random).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Session_Id))
                          then
                             (Cursors (F_Session_Id).Last - Cursors (F_Session_Id).First + 1 = RFLX_Types.Bit_Length (Cursors (F_Session_Id_Len).Value) * 8
                              and then Cursors (F_Session_Id).First = Cursors (F_Session_Id_Len).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Suites_Len))
                          then
                             (Cursors (F_Suites_Len).Last - Cursors (F_Suites_Len).First + 1 = 16
                              and then Cursors (F_Suites_Len).First = Cursors (F_Session_Id).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Cipher_Suites))
                          then
                             (Cursors (F_Cipher_Suites).Last - Cursors (F_Cipher_Suites).First + 1 = RFLX_Types.Bit_Length (Cursors (F_Suites_Len).Value) * 8
                              and then Cursors (F_Cipher_Suites).First = Cursors (F_Suites_Len).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Compression_Len))
                          then
                             (Cursors (F_Compression_Len).Last - Cursors (F_Compression_Len).First + 1 = 8
                              and then Cursors (F_Compression_Len).First = Cursors (F_Cipher_Suites).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Compression_Methods))
                          then
                             (Cursors (F_Compression_Methods).Last - Cursors (F_Compression_Methods).First + 1 = RFLX_Types.Bit_Length (Cursors (F_Compression_Len).Value) * 8
                              and then Cursors (F_Compression_Methods).First = Cursors (F_Compression_Len).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Extensions_Len))
                          then
                             (Cursors (F_Extensions_Len).Last - Cursors (F_Extensions_Len).First + 1 = 16
                              and then Cursors (F_Extensions_Len).First = Cursors (F_Compression_Methods).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Extensions))
                          then
                             (Cursors (F_Extensions).Last - Cursors (F_Extensions).First + 1 = RFLX_Types.Bit_Length (Cursors (F_Extensions_Len).Value) * 8
                              and then Cursors (F_Extensions).First = Cursors (F_Extensions_Len).Last + 1))))
   with
     Post =>
       True;

   pragma Warnings (On, """Buffer"" is not modified, could be of access constant type");

   pragma Warnings (On, "postcondition does not mention function result");

   type Context (Buffer_First, Buffer_Last : RFLX_Types.Index := RFLX_Types.Index'First; First : RFLX_Types.Bit_Index := RFLX_Types.Bit_Index'First; Last : RFLX_Types.Bit_Length := RFLX_Types.Bit_Length'First) is
      record
         Verified_Last : RFLX_Types.Bit_Length := First - 1;
         Written_Last : RFLX_Types.Bit_Length := First - 1;
         Buffer : RFLX_Types.Bytes_Ptr := null;
         Cursors : Field_Cursors := (others => <>);
      end record
   with
     Dynamic_Predicate =>
       Valid_Context (Context.Buffer_First, Context.Buffer_Last, Context.First, Context.Last, Context.Verified_Last, Context.Written_Last, Context.Buffer, Context.Cursors);

   function Initialized (Ctx : Context) return Boolean is
     (Ctx.Verified_Last = Ctx.First - 1
      and then Valid_Next (Ctx, F_Legacy_Version_Field)
      and then RFLX.Client_Hello.Message.Field_First (Ctx, RFLX.Client_Hello.Message.F_Legacy_Version_Field) rem RFLX_Types.Byte'Size = 1
      and then Available_Space (Ctx, F_Legacy_Version_Field) = Ctx.Last - Ctx.First + 1
      and then (for all F in Field =>
                   Invalid (Ctx, F)));

   function Read (Ctx : Context) return RFLX_Types.Bytes is
     (Ctx.Buffer.all (RFLX_Types.To_Index (Ctx.First) .. RFLX_Types.To_Index (Ctx.Verified_Last)));

   function Has_Buffer (Ctx : Context) return Boolean is
     (Ctx.Buffer /= null);

   function Buffer_Length (Ctx : Context) return RFLX_Types.Length is
     (Ctx.Buffer'Length);

   function Buffer_Size (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Buffer'Length * RFLX_Types.Byte'Size);

   function Size (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Verified_Last - Ctx.First + 1);

   function Byte_Size (Ctx : Context) return RFLX_Types.Length is
     (RFLX_Types.To_Length (Size (Ctx)));

   function Message_Last (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Verified_Last);

   function Written_Last (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Written_Last);

   function Valid_Value (Fld : Field; Val : RFLX_Types.Base_Integer) return Boolean is
     (case Fld is
          when F_Legacy_Version_Field =>
             RFLX.Client_Hello.Valid_Legacy_Version (Val),
          when F_Random =>
             True,
          when F_Session_Id_Len =>
             RFLX.Client_Hello.Valid_Session_Id_Length (Val),
          when F_Session_Id =>
             True,
          when F_Suites_Len =>
             RFLX.Client_Hello.Valid_Suites_Length (Val),
          when F_Cipher_Suites =>
             True,
          when F_Compression_Len =>
             RFLX.Client_Hello.Valid_Compression_Length (Val),
          when F_Compression_Methods =>
             True,
          when F_Extensions_Len =>
             RFLX.Client_Hello.Valid_Extensions_Length (Val),
          when F_Extensions =>
             True);

   function Field_Condition (Ctx : Context; Fld : Field) return Boolean is
     (case Fld is
          when F_Legacy_Version_Field | F_Random | F_Session_Id_Len | F_Session_Id | F_Suites_Len | F_Cipher_Suites | F_Compression_Len | F_Compression_Methods | F_Extensions_Len | F_Extensions =>
             True);

   function Field_Size (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Length is
     (Field_Size_Internal (Ctx.Cursors, Ctx.First, Ctx.Verified_Last, Ctx.Written_Last, Fld));

   function Field_First (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Index is
     (Field_First_Internal (Ctx.Cursors, Ctx.First, Ctx.Verified_Last, Ctx.Written_Last, Fld));

   function Field_Last (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Length is
     (Field_First (Ctx, Fld) + Field_Size (Ctx, Fld) - 1);

   function Valid_Next (Ctx : Context; Fld : Field) return Boolean is
     (Valid_Next_Internal (Ctx.Cursors, Ctx.First, Ctx.Verified_Last, Ctx.Written_Last, Fld));

   function Available_Space (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Length is
     (Ctx.Last - Field_First (Ctx, Fld) + 1);

   function Sufficient_Space (Ctx : Context; Fld : Field) return Boolean is
     (Available_Space (Ctx, Fld) >= Field_Size (Ctx, Fld));

   function Present (Ctx : Context; Fld : Field) return Boolean is
     (Well_Formed (Ctx.Cursors (Fld))
      and then Ctx.Cursors (Fld).First < Ctx.Cursors (Fld).Last + 1);

   function Well_Formed (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Valid
      or Ctx.Cursors (Fld).State = S_Well_Formed);

   function Valid (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Valid
      and then Ctx.Cursors (Fld).First < Ctx.Cursors (Fld).Last + 1);

   function Incomplete (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Incomplete);

   function Invalid (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Invalid
      or Ctx.Cursors (Fld).State = S_Incomplete);

   function Well_Formed_Message (Ctx : Context) return Boolean is
     (Well_Formed (Ctx, F_Extensions));

   function Valid_Message (Ctx : Context) return Boolean is
     (Valid (Ctx, F_Extensions));

   function Incomplete_Message (Ctx : Context) return Boolean is
     ((for some F in Field =>
          Incomplete (Ctx, F)));

   function Get_Legacy_Version_Field (Ctx : Context) return RFLX.Client_Hello.Legacy_Version is
     (To_Actual (Ctx.Cursors (F_Legacy_Version_Field).Value));

   function Get_Session_Id_Len (Ctx : Context) return RFLX.Client_Hello.Session_Id_Length is
     (To_Actual (Ctx.Cursors (F_Session_Id_Len).Value));

   function Get_Suites_Len (Ctx : Context) return RFLX.Client_Hello.Suites_Length is
     (To_Actual (Ctx.Cursors (F_Suites_Len).Value));

   function Get_Compression_Len (Ctx : Context) return RFLX.Client_Hello.Compression_Length is
     (To_Actual (Ctx.Cursors (F_Compression_Len).Value));

   function Get_Extensions_Len (Ctx : Context) return RFLX.Client_Hello.Extensions_Length is
     (To_Actual (Ctx.Cursors (F_Extensions_Len).Value));

   function Valid_Size (Ctx : Context; Fld : Field; Size : RFLX_Types.Bit_Length) return Boolean is
     (Size = Field_Size (Ctx, Fld))
   with
     Pre =>
       RFLX.Client_Hello.Message.Valid_Next (Ctx, Fld);

   function Valid_Length (Ctx : Context; Fld : Field; Length : RFLX_Types.Length) return Boolean is
     (Valid_Size (Ctx, Fld, RFLX_Types.To_Bit_Length (Length)));

   function Complete_Extensions (Ctx : Context; Seq_Ctx : RFLX.TLS_Extensions.Extension_List.Context) return Boolean is
     (RFLX.TLS_Extensions.Extension_List.Valid (Seq_Ctx)
      and RFLX.TLS_Extensions.Extension_List.Size (Seq_Ctx) = Field_Size (Ctx, F_Extensions));

   function Context_Cursor (Ctx : Context; Fld : Field) return Field_Cursor is
     (Ctx.Cursors (Fld));

   function Context_Cursors (Ctx : Context) return Field_Cursors is
     (Ctx.Cursors);

   function Context_Cursors_Index (Cursors : Field_Cursors; Fld : Field) return Field_Cursor is
     (Cursors (Fld));

end RFLX.Client_Hello.Message;
