   procedure Initialize_Random_Private (Ctx : in out Context; Length : RFLX_Types.Length)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.Server_Hello.Message.Has_Buffer (Ctx)
       and then RFLX.Server_Hello.Message.Valid_Next (Ctx, RFLX.Server_Hello.Message.F_Random)
       and then RFLX.Server_Hello.Message.Valid_Length (Ctx, RFLX.Server_Hello.Message.F_Random, Length)
       and then RFLX_Types.To_Length (RFLX.Server_Hello.Message.Available_Space (Ctx, RFLX.Server_Hello.Message.F_Random)) >= Length,
     Post =>
       Has_Buffer (Ctx)
       and then Well_Formed (Ctx, F_Random)
       and then Field_Size (Ctx, F_Random) = RFLX_Types.To_Bit_Length (Length)
       and then Ctx.Verified_Last = Field_Last (Ctx, F_Random)
       and then Invalid (Ctx, F_Session_Id_Len)
       and then Invalid (Ctx, F_Session_Id_Echo)
       and then Invalid (Ctx, F_Selected_Cipher_Suite)
       and then Invalid (Ctx, F_Compression_Method_Val)
       and then Invalid (Ctx, F_Extensions_Len)
       and then Invalid (Ctx, F_Extensions)
       and then Valid_Next (Ctx, F_Session_Id_Len)
       and then Ctx.Buffer_First = Ctx.Buffer_First'Old
       and then Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and then Ctx.First = Ctx.First'Old
       and then Ctx.Last = Ctx.Last'Old
       and then Valid_Next (Ctx, F_Random) = Valid_Next (Ctx, F_Random)'Old
       and then Field_First (Ctx, F_Random) = Field_First (Ctx, F_Random)'Old
   is
      First : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Random);
      Last : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Random) + RFLX_Types.Bit_Length (Length) * RFLX_Types.Byte'Size - 1;
   begin
      pragma Assert (Last mod RFLX_Types.Byte'Size = 0);
      Reset_Dependent_Fields (Ctx, F_Random);
      pragma Warnings (Off, "attribute Update is an obsolescent feature");
      Ctx := Ctx'Update (Verified_Last => Last, Written_Last => Last);
      pragma Warnings (On, "attribute Update is an obsolescent feature");
      Ctx.Cursors (F_Random) := (State => S_Well_Formed, First => First, Last => Last, Value => 0);
   end Initialize_Random_Private;

   procedure Initialize_Random (Ctx : in out Context) is
   begin
      Initialize_Random_Private (Ctx, RFLX_Types.To_Length (Field_Size (Ctx, F_Random)));
   end Initialize_Random;

   procedure Initialize_Session_Id_Echo_Private (Ctx : in out Context; Length : RFLX_Types.Length)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.Server_Hello.Message.Has_Buffer (Ctx)
       and then RFLX.Server_Hello.Message.Valid_Next (Ctx, RFLX.Server_Hello.Message.F_Session_Id_Echo)
       and then RFLX.Server_Hello.Message.Valid_Length (Ctx, RFLX.Server_Hello.Message.F_Session_Id_Echo, Length)
       and then RFLX_Types.To_Length (RFLX.Server_Hello.Message.Available_Space (Ctx, RFLX.Server_Hello.Message.F_Session_Id_Echo)) >= Length,
     Post =>
       Has_Buffer (Ctx)
       and then Well_Formed (Ctx, F_Session_Id_Echo)
       and then Field_Size (Ctx, F_Session_Id_Echo) = RFLX_Types.To_Bit_Length (Length)
       and then Ctx.Verified_Last = Field_Last (Ctx, F_Session_Id_Echo)
       and then Invalid (Ctx, F_Selected_Cipher_Suite)
       and then Invalid (Ctx, F_Compression_Method_Val)
       and then Invalid (Ctx, F_Extensions_Len)
       and then Invalid (Ctx, F_Extensions)
       and then Valid_Next (Ctx, F_Selected_Cipher_Suite)
       and then Ctx.Buffer_First = Ctx.Buffer_First'Old
       and then Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and then Ctx.First = Ctx.First'Old
       and then Ctx.Last = Ctx.Last'Old
       and then Valid_Next (Ctx, F_Session_Id_Echo) = Valid_Next (Ctx, F_Session_Id_Echo)'Old
       and then Get_Session_Id_Len (Ctx) = Get_Session_Id_Len (Ctx)'Old
       and then Field_First (Ctx, F_Session_Id_Echo) = Field_First (Ctx, F_Session_Id_Echo)'Old
   is
      First : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Session_Id_Echo);
      Last : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Session_Id_Echo) + RFLX_Types.Bit_Length (Length) * RFLX_Types.Byte'Size - 1;
   begin
      pragma Assert (Last mod RFLX_Types.Byte'Size = 0);
      Reset_Dependent_Fields (Ctx, F_Session_Id_Echo);
      pragma Warnings (Off, "attribute Update is an obsolescent feature");
      Ctx := Ctx'Update (Verified_Last => Last, Written_Last => Last);
      pragma Warnings (On, "attribute Update is an obsolescent feature");
      Ctx.Cursors (F_Session_Id_Echo) := (State => S_Well_Formed, First => First, Last => Last, Value => 0);
   end Initialize_Session_Id_Echo_Private;

   procedure Initialize_Session_Id_Echo (Ctx : in out Context) is
   begin
      Initialize_Session_Id_Echo_Private (Ctx, RFLX_Types.To_Length (Field_Size (Ctx, F_Session_Id_Echo)));
   end Initialize_Session_Id_Echo;

   procedure Initialize_Extensions_Private (Ctx : in out Context; Length : RFLX_Types.Length)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.Server_Hello.Message.Has_Buffer (Ctx)
       and then RFLX.Server_Hello.Message.Valid_Next (Ctx, RFLX.Server_Hello.Message.F_Extensions)
       and then RFLX.Server_Hello.Message.Valid_Length (Ctx, RFLX.Server_Hello.Message.F_Extensions, Length)
       and then RFLX_Types.To_Length (RFLX.Server_Hello.Message.Available_Space (Ctx, RFLX.Server_Hello.Message.F_Extensions)) >= Length,
     Post =>
       Has_Buffer (Ctx)
       and then Well_Formed (Ctx, F_Extensions)
       and then Field_Size (Ctx, F_Extensions) = RFLX_Types.To_Bit_Length (Length)
       and then Ctx.Verified_Last = Field_Last (Ctx, F_Extensions)
       and then Ctx.Buffer_First = Ctx.Buffer_First'Old
       and then Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and then Ctx.First = Ctx.First'Old
       and then Ctx.Last = Ctx.Last'Old
       and then Valid_Next (Ctx, F_Extensions) = Valid_Next (Ctx, F_Extensions)'Old
       and then Get_Session_Id_Len (Ctx) = Get_Session_Id_Len (Ctx)'Old
       and then Get_Selected_Cipher_Suite (Ctx) = Get_Selected_Cipher_Suite (Ctx)'Old
       and then Get_Extensions_Len (Ctx) = Get_Extensions_Len (Ctx)'Old
       and then Field_First (Ctx, F_Extensions) = Field_First (Ctx, F_Extensions)'Old
   is
      First : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Extensions);
      Last : constant RFLX_Types.Bit_Index := Field_First (Ctx, F_Extensions) + RFLX_Types.Bit_Length (Length) * RFLX_Types.Byte'Size - 1;
   begin
      pragma Assert (Last mod RFLX_Types.Byte'Size = 0);
      Reset_Dependent_Fields (Ctx, F_Extensions);
      pragma Warnings (Off, "attribute Update is an obsolescent feature");
      Ctx := Ctx'Update (Verified_Last => Last, Written_Last => Last);
      pragma Warnings (On, "attribute Update is an obsolescent feature");
      Ctx.Cursors (F_Extensions) := (State => S_Well_Formed, First => First, Last => Last, Value => 0);
   end Initialize_Extensions_Private;

   procedure Initialize_Extensions (Ctx : in out Context) is
   begin
      Initialize_Extensions_Private (Ctx, RFLX_Types.To_Length (Field_Size (Ctx, F_Extensions)));
   end Initialize_Extensions;

   procedure Set_Random (Ctx : in out Context; Data : RFLX_Types.Bytes) is
      Buffer_First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Random));
      Buffer_Last : constant RFLX_Types.Index := Buffer_First + Data'Length - 1;
   begin
      Initialize_Random_Private (Ctx, Data'Length);
      pragma Assert (Buffer_Last = RFLX_Types.To_Index (Field_Last (Ctx, F_Random)));
      Ctx.Buffer.all (Buffer_First .. Buffer_Last) := Data;
      pragma Assert (Ctx.Buffer.all (RFLX_Types.To_Index (Field_First (Ctx, F_Random)) .. RFLX_Types.To_Index (Field_Last (Ctx, F_Random))) = Data);
   end Set_Random;

   procedure Set_Session_Id_Echo (Ctx : in out Context; Data : RFLX_Types.Bytes) is
      Buffer_First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Session_Id_Echo));
      Buffer_Last : constant RFLX_Types.Index := Buffer_First + Data'Length - 1;
   begin
      Initialize_Session_Id_Echo_Private (Ctx, Data'Length);
      pragma Assert (Buffer_Last = RFLX_Types.To_Index (Field_Last (Ctx, F_Session_Id_Echo)));
      Ctx.Buffer.all (Buffer_First .. Buffer_Last) := Data;
      pragma Assert (Ctx.Buffer.all (RFLX_Types.To_Index (Field_First (Ctx, F_Session_Id_Echo)) .. RFLX_Types.To_Index (Field_Last (Ctx, F_Session_Id_Echo))) = Data);
   end Set_Session_Id_Echo;

   procedure Set_Extensions (Ctx : in out Context; Data : RFLX_Types.Bytes) is
      Buffer_First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Extensions));
      Buffer_Last : constant RFLX_Types.Index := Buffer_First + Data'Length - 1;
   begin
      Initialize_Extensions_Private (Ctx, Data'Length);
      pragma Assert (Buffer_Last = RFLX_Types.To_Index (Field_Last (Ctx, F_Extensions)));
      Ctx.Buffer.all (Buffer_First .. Buffer_Last) := Data;
      pragma Assert (Ctx.Buffer.all (RFLX_Types.To_Index (Field_First (Ctx, F_Extensions)) .. RFLX_Types.To_Index (Field_Last (Ctx, F_Extensions))) = Data);
   end Set_Extensions;

   procedure Generic_Set_Random (Ctx : in out Context; Length : RFLX_Types.Length) is
      First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Random));
   begin
      if Length > 0 then
         Process_Random (Ctx.Buffer.all (First .. First + RFLX_Types.Index (Length) - 1));
      end if;
      pragma Assert (RFLX.Server_Hello.Message.Valid_Length (Ctx, RFLX.Server_Hello.Message.F_Random, Length));
      Initialize_Random_Private (Ctx, Length);
   end Generic_Set_Random;

   procedure Generic_Set_Session_Id_Echo (Ctx : in out Context; Length : RFLX_Types.Length) is
      First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Session_Id_Echo));
   begin
      if Length > 0 then
         Process_Session_Id_Echo (Ctx.Buffer.all (First .. First + RFLX_Types.Index (Length) - 1));
      end if;
      pragma Assert (RFLX.Server_Hello.Message.Valid_Length (Ctx, RFLX.Server_Hello.Message.F_Session_Id_Echo, Length));
      Initialize_Session_Id_Echo_Private (Ctx, Length);
   end Generic_Set_Session_Id_Echo;

   procedure Generic_Set_Extensions (Ctx : in out Context; Length : RFLX_Types.Length) is
      First : constant RFLX_Types.Index := RFLX_Types.To_Index (Field_First (Ctx, F_Extensions));
   begin
      if Length > 0 then
         Process_Extensions (Ctx.Buffer.all (First .. First + RFLX_Types.Index (Length) - 1));
      end if;
      pragma Assert (RFLX.Server_Hello.Message.Valid_Length (Ctx, RFLX.Server_Hello.Message.F_Extensions, Length));
      Initialize_Extensions_Private (Ctx, Length);
   end Generic_Set_Extensions;

   procedure To_Structure (Ctx : Context; Struct : out Structure) is
   begin
      Struct.Legacy_Version_Field := Get_Legacy_Version_Field (Ctx);
      Struct.Random := (others => 0);
      Get_Random (Ctx, Struct.Random (Struct.Random'First .. Struct.Random'First + RFLX_Types.Index (RFLX_Types.To_Length (Field_Size (Ctx, F_Random)) + 1) - 2));
      Struct.Session_Id_Len := Get_Session_Id_Len (Ctx);
      Struct.Session_Id_Echo := (others => 0);
      Get_Session_Id_Echo (Ctx, Struct.Session_Id_Echo (Struct.Session_Id_Echo'First .. Struct.Session_Id_Echo'First + RFLX_Types.Index (RFLX_Types.To_Length (Field_Size (Ctx, F_Session_Id_Echo)) + 1) - 2));
      Struct.Selected_Cipher_Suite := Get_Selected_Cipher_Suite (Ctx);
      Struct.Compression_Method_Val := Get_Compression_Method_Val (Ctx);
      Struct.Extensions_Len := Get_Extensions_Len (Ctx);
      Struct.Extensions := (others => 0);
      Get_Extensions (Ctx, Struct.Extensions (Struct.Extensions'First .. Struct.Extensions'First + RFLX_Types.Index (RFLX_Types.To_Length (Field_Size (Ctx, F_Extensions)) + 1) - 2));
   end To_Structure;

   procedure To_Context (Struct : Structure; Ctx : in out Context) is
   begin
      Reset (Ctx);
      Set_Legacy_Version_Field (Ctx, Struct.Legacy_Version_Field);
      Set_Random (Ctx, Struct.Random);
      Set_Session_Id_Len (Ctx, Struct.Session_Id_Len);
      Set_Session_Id_Echo (Ctx, Struct.Session_Id_Echo (Struct.Session_Id_Echo'First .. Struct.Session_Id_Echo'First + RFLX_Types.Index (RFLX_Types.To_Length (RFLX_Types.Bit_Length (Struct.Session_Id_Len) * 8) + 1) - 2));
      Set_Selected_Cipher_Suite (Ctx, Struct.Selected_Cipher_Suite);
      Set_Compression_Method_Val (Ctx, Struct.Compression_Method_Val);
      Set_Extensions_Len (Ctx, Struct.Extensions_Len);
      Set_Extensions (Ctx, Struct.Extensions (Struct.Extensions'First .. Struct.Extensions'First + RFLX_Types.Index (RFLX_Types.To_Length (RFLX_Types.Bit_Length (Struct.Extensions_Len) * 8) + 1) - 2));
   end To_Context;

end RFLX.Server_Hello.Message;
