       and then RFLX.New_Session_Ticket.Message.Valid_Next (Ctx, RFLX.New_Session_Ticket.Message.F_Ticket)
       and then RFLX.New_Session_Ticket.Message.Available_Space (Ctx, RFLX.New_Session_Ticket.Message.F_Ticket) >= RFLX.New_Session_Ticket.Message.Field_Size (Ctx, RFLX.New_Session_Ticket.Message.F_Ticket)
       and then RFLX.New_Session_Ticket.Message.Valid_Length (Ctx, RFLX.New_Session_Ticket.Message.F_Ticket, Length)
       and then RFLX_Types.To_Length (RFLX.New_Session_Ticket.Message.Available_Space (Ctx, RFLX.New_Session_Ticket.Message.F_Ticket)) >= Length
       and then Process_Data_Pre (Length),
     Post =>
       Has_Buffer (Ctx)
       and Well_Formed (Ctx, F_Ticket)
       and Invalid (Ctx, F_Extensions_Len)
       and Invalid (Ctx, F_Extensions)
       and Valid_Next (Ctx, F_Extensions_Len)
       and Ctx.Buffer_First = Ctx.Buffer_First'Old
       and Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and Ctx.First = Ctx.First'Old
       and Ctx.Last = Ctx.Last'Old
       and Valid_Next (Ctx, F_Ticket) = Valid_Next (Ctx, F_Ticket)'Old
       and Get_Ticket_Lifetime (Ctx) = Get_Ticket_Lifetime (Ctx)'Old
       and Get_Ticket_Age_Add (Ctx) = Get_Ticket_Age_Add (Ctx)'Old
       and Get_Nonce_Len (Ctx) = Get_Nonce_Len (Ctx)'Old
       and Get_Ticket_Len (Ctx) = Get_Ticket_Len (Ctx)'Old
       and Field_First (Ctx, F_Ticket) = Field_First (Ctx, F_Ticket)'Old;

   generic
      with procedure Process_Extensions (Extensions : out RFLX_Types.Bytes);
      with function Process_Data_Pre (Length : RFLX_Types.Length) return Boolean;
   procedure Generic_Set_Extensions (Ctx : in out Context; Length : RFLX_Types.Length)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.New_Session_Ticket.Message.Has_Buffer (Ctx)
       and then RFLX.New_Session_Ticket.Message.Valid_Next (Ctx, RFLX.New_Session_Ticket.Message.F_Extensions)
       and then RFLX.New_Session_Ticket.Message.Available_Space (Ctx, RFLX.New_Session_Ticket.Message.F_Extensions) >= RFLX.New_Session_Ticket.Message.Field_Size (Ctx, RFLX.New_Session_Ticket.Message.F_Extensions)
       and then RFLX.New_Session_Ticket.Message.Valid_Length (Ctx, RFLX.New_Session_Ticket.Message.F_Extensions, Length)
       and then RFLX_Types.To_Length (RFLX.New_Session_Ticket.Message.Available_Space (Ctx, RFLX.New_Session_Ticket.Message.F_Extensions)) >= Length
       and then Process_Data_Pre (Length),
     Post =>
       Has_Buffer (Ctx)
       and Well_Formed (Ctx, F_Extensions)
       and (if Well_Formed_Message (Ctx) then Message_Last (Ctx) = Field_Last (Ctx, F_Extensions))
       and Ctx.Buffer_First = Ctx.Buffer_First'Old
       and Ctx.Buffer_Last = Ctx.Buffer_Last'Old
       and Ctx.First = Ctx.First'Old
       and Ctx.Last = Ctx.Last'Old
       and Valid_Next (Ctx, F_Extensions) = Valid_Next (Ctx, F_Extensions)'Old
       and Get_Ticket_Lifetime (Ctx) = Get_Ticket_Lifetime (Ctx)'Old
       and Get_Ticket_Age_Add (Ctx) = Get_Ticket_Age_Add (Ctx)'Old
       and Get_Nonce_Len (Ctx) = Get_Nonce_Len (Ctx)'Old
       and Get_Ticket_Len (Ctx) = Get_Ticket_Len (Ctx)'Old
       and Get_Extensions_Len (Ctx) = Get_Extensions_Len (Ctx)'Old
       and Field_First (Ctx, F_Extensions) = Field_First (Ctx, F_Extensions)'Old;

   function Context_Cursor (Ctx : Context; Fld : Field) return Field_Cursor
   with
     Annotate =>
       (GNATprove, Inline_For_Proof),
     Ghost;

   function Context_Cursors (Ctx : Context) return Field_Cursors
   with
     Annotate =>
       (GNATprove, Inline_For_Proof),
     Ghost;

   function Context_Cursors_Index (Cursors : Field_Cursors; Fld : Field) return Field_Cursor
   with
     Annotate =>
       (GNATprove, Inline_For_Proof),
     Ghost;

   type Structure is
      record
         Ticket_Lifetime : RFLX.New_Session_Ticket.Lifetime;
         Ticket_Age_Add : RFLX.New_Session_Ticket.Age_Add;
         Nonce_Len : RFLX.New_Session_Ticket.Nonce_Length;
         Ticket_Nonce : RFLX_Types.Bytes (RFLX_Types.Index'First .. RFLX_Types.Index'First + 254);
         Ticket_Len : RFLX.New_Session_Ticket.Ticket_Length;
         Ticket : RFLX_Types.Bytes (RFLX_Types.Index'First .. RFLX_Types.Index'First + 65534);
         Extensions_Len : RFLX.New_Session_Ticket.Extensions_Length;
         Extensions : RFLX_Types.Bytes (RFLX_Types.Index'First .. RFLX_Types.Index'First + 65533);
      end record;

   function Valid_Structure (Unused_Struct : Structure) return Boolean;

   procedure To_Structure (Ctx : Context; Struct : out Structure)
   with
     Pre =>
       RFLX.New_Session_Ticket.Message.Has_Buffer (Ctx)
       and then RFLX.New_Session_Ticket.Message.Well_Formed_Message (Ctx),
     Post =>
       Valid_Structure (Struct);

   function Sufficient_Buffer_Length (Ctx : Context; Struct : Structure) return Boolean;

   procedure To_Context (Struct : Structure; Ctx : in out Context)
   with
     Pre =>
       not Ctx'Constrained
       and then RFLX.New_Session_Ticket.Message.Has_Buffer (Ctx)
       and then RFLX.New_Session_Ticket.Message.Valid_Structure (Struct)
       and then RFLX.New_Session_Ticket.Message.Sufficient_Buffer_Length (Ctx, Struct),
     Post =>
       Has_Buffer (Ctx)
       and Well_Formed_Message (Ctx)
       and Ctx.Buffer_First = Ctx.Buffer_First'Old
       and Ctx.Buffer_Last = Ctx.Buffer_Last'Old;

   function Field_Size_Ticket_Lifetime (Struct : Structure) return RFLX_Types.Bit_Length
   with
     Pre =>
       Valid_Structure (Struct);

   function Field_Size_Ticket_Age_Add (Struct : Structure) return RFLX_Types.Bit_Length
   with
     Pre =>
       Valid_Structure (Struct);

   function Field_Size_Nonce_Len (Struct : Structure) return RFLX_Types.Bit_Length
   with
     Pre =>
       Valid_Structure (Struct);

   function Field_Size_Ticket_Nonce (Struct : Structure) return RFLX_Types.Bit_Length
   with
     Pre =>
       Valid_Structure (Struct);

   function Field_Size_Ticket_Len (Struct : Structure) return RFLX_Types.Bit_Length
   with
     Pre =>
       Valid_Structure (Struct);

   function Field_Size_Ticket (Struct : Structure) return RFLX_Types.Bit_Length
   with
     Pre =>
       Valid_Structure (Struct);

   function Field_Size_Extensions_Len (Struct : Structure) return RFLX_Types.Bit_Length
   with
     Pre =>
       Valid_Structure (Struct);

   function Field_Size_Extensions (Struct : Structure) return RFLX_Types.Bit_Length
   with
     Pre =>
       Valid_Structure (Struct);

private

   type Cursor_State is (S_Valid, S_Well_Formed, S_Invalid, S_Incomplete);

   type Field_Cursor is
      record
         State : Cursor_State := S_Invalid;
         First : RFLX_Types.Bit_Index := RFLX_Types.Bit_Index'First;
         Last : RFLX_Types.Bit_Length := RFLX_Types.Bit_Length'First;
         Value : RFLX_Types.Base_Integer := 0;
      end record;

   type Field_Cursors is array (Virtual_Field) of Field_Cursor;

   function Well_Formed (Cursor : Field_Cursor) return Boolean is
     (Cursor.State = S_Valid
      or Cursor.State = S_Well_Formed);

   function Valid (Cursor : Field_Cursor) return Boolean is
     (Cursor.State = S_Valid);

   function Invalid (Cursor : Field_Cursor) return Boolean is
     (Cursor.State = S_Invalid
      or Cursor.State = S_Incomplete);

   pragma Warnings (Off, "postcondition does not mention function result");

   function Cursors_Invariant (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length) return Boolean is
     ((for all F in Field =>
          (if
              Well_Formed (Cursors (F))
           then
              Cursors (F).First >= First
              and Cursors (F).Last <= Verified_Last
              and Cursors (F).First <= Cursors (F).Last + 1
              and Valid_Value (F, Cursors (F).Value))))
   with
     Post =>
       True;

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (Off, "formal parameter ""*"" is not referenced");

   pragma Warnings (Off, "postcondition does not mention function result");

   pragma Warnings (Off, "unused variable ""*""");

   function Valid_Predecessors_Invariant (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return Boolean is
     ((if Well_Formed (Cursors (F_Ticket_Lifetime)) then True)
      and then (if Well_Formed (Cursors (F_Ticket_Age_Add)) then Valid (Cursors (F_Ticket_Lifetime)))
      and then (if Well_Formed (Cursors (F_Nonce_Len)) then Valid (Cursors (F_Ticket_Age_Add)))
      and then (if Well_Formed (Cursors (F_Ticket_Nonce)) then Valid (Cursors (F_Nonce_Len)))
      and then (if Well_Formed (Cursors (F_Ticket_Len)) then Well_Formed (Cursors (F_Ticket_Nonce)))
      and then (if Well_Formed (Cursors (F_Ticket)) then Valid (Cursors (F_Ticket_Len)))
      and then (if Well_Formed (Cursors (F_Extensions_Len)) then Well_Formed (Cursors (F_Ticket)))
      and then (if Well_Formed (Cursors (F_Extensions)) then Valid (Cursors (F_Extensions_Len))))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last),
     Post =>
       True;

   pragma Warnings (On, "unused variable ""*""");

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (On, "formal parameter ""*"" is not referenced");

   pragma Warnings (Off, "postcondition does not mention function result");

   function Valid_Next_Internal (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Fld : Field) return Boolean is
     (case Fld is
          when F_Ticket_Lifetime =>
             True,
          when F_Ticket_Age_Add =>
             (Valid (Cursors (F_Ticket_Lifetime))
              and then True),
          when F_Nonce_Len =>
             (Valid (Cursors (F_Ticket_Age_Add))
              and then True),
          when F_Ticket_Nonce =>
             (Valid (Cursors (F_Nonce_Len))
              and then True),
          when F_Ticket_Len =>
             (Well_Formed (Cursors (F_Ticket_Nonce))
              and then True),
          when F_Ticket =>
             (Valid (Cursors (F_Ticket_Len))
              and then True),
          when F_Extensions_Len =>
             (Well_Formed (Cursors (F_Ticket))
              and then True),
          when F_Extensions =>
             (Valid (Cursors (F_Extensions_Len))
              and then True))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last),
     Post =>
       True;

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (Off, "unused variable ""*""");

   pragma Warnings (Off, "formal parameter ""*"" is not referenced");

   function Field_Size_Internal (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Fld : Field) return RFLX_Types.Bit_Length'Base is
     (case Fld is
          when F_Ticket_Lifetime | F_Ticket_Age_Add =>
             32,
          when F_Nonce_Len =>
             8,
          when F_Ticket_Nonce =>
             RFLX_Types.Bit_Length (Cursors (F_Nonce_Len).Value) * 8,
          when F_Ticket_Len =>
             16,
          when F_Ticket =>
             RFLX_Types.Bit_Length (Cursors (F_Ticket_Len).Value) * 8,
          when F_Extensions_Len =>
             16,
          when F_Extensions =>
             RFLX_Types.Bit_Length (Cursors (F_Extensions_Len).Value) * 8)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, Fld);

   pragma Warnings (On, "formal parameter ""*"" is not referenced");

   pragma Warnings (On, "unused variable ""*""");

   pragma Warnings (Off, "postcondition does not mention function result");

   pragma Warnings (Off, "unused variable ""*""");

   pragma Warnings (Off, "no recursive call visible");

   pragma Warnings (Off, "formal parameter ""*"" is not referenced");

   function Field_First_Ticket_Lifetime (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Ticket_Lifetime);

   function Field_First_Ticket_Age_Add (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 32)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Ticket_Age_Add);

   function Field_First_Nonce_Len (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 64)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Nonce_Len);

   function Field_First_Ticket_Nonce (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (First + 72)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Ticket_Nonce);

   function Field_First_Ticket_Len (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (Field_First_Ticket_Nonce (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Ticket_Nonce))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Ticket_Len);

   function Field_First_Ticket (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (Field_First_Ticket_Nonce (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Ticket_Nonce) + 16)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Ticket);

   function Field_First_Extensions_Len (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (Field_First_Ticket (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Ticket))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Extensions_Len);

   function Field_First_Extensions (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length) return RFLX_Types.Bit_Index'Base is
     (Field_First_Ticket (Cursors, First, Verified_Last, Written_Last) + Field_Size_Internal (Cursors, First, Verified_Last, Written_Last, F_Ticket) + 16)
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, F_Extensions);

   function Field_First_Internal (Cursors : Field_Cursors; First : RFLX_Types.Bit_Index; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Fld : Field) return RFLX_Types.Bit_Index'Base is
     (case Fld is
          when F_Ticket_Lifetime =>
             Field_First_Ticket_Lifetime (Cursors, First, Verified_Last, Written_Last),
          when F_Ticket_Age_Add =>
             Field_First_Ticket_Age_Add (Cursors, First, Verified_Last, Written_Last),
          when F_Nonce_Len =>
             Field_First_Nonce_Len (Cursors, First, Verified_Last, Written_Last),
          when F_Ticket_Nonce =>
             Field_First_Ticket_Nonce (Cursors, First, Verified_Last, Written_Last),
          when F_Ticket_Len =>
             Field_First_Ticket_Len (Cursors, First, Verified_Last, Written_Last),
          when F_Ticket =>
             Field_First_Ticket (Cursors, First, Verified_Last, Written_Last),
          when F_Extensions_Len =>
             Field_First_Extensions_Len (Cursors, First, Verified_Last, Written_Last),
          when F_Extensions =>
             Field_First_Extensions (Cursors, First, Verified_Last, Written_Last))
   with
     Pre =>
       Cursors_Invariant (Cursors, First, Verified_Last)
       and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
       and then Valid_Next_Internal (Cursors, First, Verified_Last, Written_Last, Fld),
     Post =>
       True;

   pragma Warnings (On, "formal parameter ""*"" is not referenced");

   pragma Warnings (On, "no recursive call visible");

   pragma Warnings (On, "unused variable ""*""");

   pragma Warnings (On, "postcondition does not mention function result");

   pragma Warnings (Off, """Buffer"" is not modified, could be of access constant type");

   pragma Warnings (Off, "postcondition does not mention function result");

   function Valid_Context (Buffer_First, Buffer_Last : RFLX_Types.Index; First : RFLX_Types.Bit_Index; Last : RFLX_Types.Bit_Length; Verified_Last : RFLX_Types.Bit_Length; Written_Last : RFLX_Types.Bit_Length; Buffer : RFLX_Types.Bytes_Ptr; Cursors : Field_Cursors) return Boolean is
     ((if
          Buffer /= null
       then
          Buffer'Length > 0
          and Buffer'First = Buffer_First
          and Buffer'Last = Buffer_Last)
      and then (RFLX_Types.To_Index (First) >= Buffer_First
                and RFLX_Types.To_Index (Last) <= Buffer_Last
                and Buffer_Last < RFLX_Types.Index'Last
                and First <= Last + 1
                and Last < RFLX_Types.Bit_Index'Last
                and First rem RFLX_Types.Byte'Size = 1
                and Last rem RFLX_Types.Byte'Size = 0)
      and then First - 1 <= Verified_Last
      and then First - 1 <= Written_Last
      and then Verified_Last <= Written_Last
      and then Written_Last <= Last
      and then First rem RFLX_Types.Byte'Size = 1
      and then Last rem RFLX_Types.Byte'Size = 0
      and then Verified_Last rem RFLX_Types.Byte'Size = 0
      and then Written_Last rem RFLX_Types.Byte'Size = 0
      and then Cursors_Invariant (Cursors, First, Verified_Last)
      and then Valid_Predecessors_Invariant (Cursors, First, Verified_Last, Written_Last)
      and then ((if
                    Well_Formed (Cursors (F_Ticket_Lifetime))
                 then
                    (Cursors (F_Ticket_Lifetime).Last - Cursors (F_Ticket_Lifetime).First + 1 = 32
                     and then Cursors (F_Ticket_Lifetime).First = First))
                and then (if
                             Well_Formed (Cursors (F_Ticket_Age_Add))
                          then
                             (Cursors (F_Ticket_Age_Add).Last - Cursors (F_Ticket_Age_Add).First + 1 = 32
                              and then Cursors (F_Ticket_Age_Add).First = Cursors (F_Ticket_Lifetime).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Nonce_Len))
                          then
                             (Cursors (F_Nonce_Len).Last - Cursors (F_Nonce_Len).First + 1 = 8
                              and then Cursors (F_Nonce_Len).First = Cursors (F_Ticket_Age_Add).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Ticket_Nonce))
                          then
                             (Cursors (F_Ticket_Nonce).Last - Cursors (F_Ticket_Nonce).First + 1 = RFLX_Types.Bit_Length (Cursors (F_Nonce_Len).Value) * 8
                              and then Cursors (F_Ticket_Nonce).First = Cursors (F_Nonce_Len).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Ticket_Len))
                          then
                             (Cursors (F_Ticket_Len).Last - Cursors (F_Ticket_Len).First + 1 = 16
                              and then Cursors (F_Ticket_Len).First = Cursors (F_Ticket_Nonce).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Ticket))
                          then
                             (Cursors (F_Ticket).Last - Cursors (F_Ticket).First + 1 = RFLX_Types.Bit_Length (Cursors (F_Ticket_Len).Value) * 8
                              and then Cursors (F_Ticket).First = Cursors (F_Ticket_Len).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Extensions_Len))
                          then
                             (Cursors (F_Extensions_Len).Last - Cursors (F_Extensions_Len).First + 1 = 16
                              and then Cursors (F_Extensions_Len).First = Cursors (F_Ticket).Last + 1))
                and then (if
                             Well_Formed (Cursors (F_Extensions))
                          then
                             (Cursors (F_Extensions).Last - Cursors (F_Extensions).First + 1 = RFLX_Types.Bit_Length (Cursors (F_Extensions_Len).Value) * 8
                              and then Cursors (F_Extensions).First = Cursors (F_Extensions_Len).Last + 1))))
   with
     Post =>
       True;

   pragma Warnings (On, """Buffer"" is not modified, could be of access constant type");

   pragma Warnings (On, "postcondition does not mention function result");

   type Context (Buffer_First, Buffer_Last : RFLX_Types.Index := RFLX_Types.Index'First; First : RFLX_Types.Bit_Index := RFLX_Types.Bit_Index'First; Last : RFLX_Types.Bit_Length := RFLX_Types.Bit_Length'First) is
      record
         Verified_Last : RFLX_Types.Bit_Length := First - 1;
         Written_Last : RFLX_Types.Bit_Length := First - 1;
         Buffer : RFLX_Types.Bytes_Ptr := null;
         Cursors : Field_Cursors := (others => <>);
      end record
   with
     Dynamic_Predicate =>
       Valid_Context (Context.Buffer_First, Context.Buffer_Last, Context.First, Context.Last, Context.Verified_Last, Context.Written_Last, Context.Buffer, Context.Cursors);

   function Initialized (Ctx : Context) return Boolean is
     (Ctx.Verified_Last = Ctx.First - 1
      and then Valid_Next (Ctx, F_Ticket_Lifetime)
      and then RFLX.New_Session_Ticket.Message.Field_First (Ctx, RFLX.New_Session_Ticket.Message.F_Ticket_Lifetime) rem RFLX_Types.Byte'Size = 1
      and then Available_Space (Ctx, F_Ticket_Lifetime) = Ctx.Last - Ctx.First + 1
      and then (for all F in Field =>
                   Invalid (Ctx, F)));

   function Read (Ctx : Context) return RFLX_Types.Bytes is
     (Ctx.Buffer.all (RFLX_Types.To_Index (Ctx.First) .. RFLX_Types.To_Index (Ctx.Verified_Last)));

   function Has_Buffer (Ctx : Context) return Boolean is
     (Ctx.Buffer /= null);

   function Buffer_Length (Ctx : Context) return RFLX_Types.Length is
     (Ctx.Buffer'Length);

   function Buffer_Size (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Buffer'Length * RFLX_Types.Byte'Size);

   function Size (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Verified_Last - Ctx.First + 1);

   function Byte_Size (Ctx : Context) return RFLX_Types.Length is
     (RFLX_Types.To_Length (Size (Ctx)));

   function Message_Last (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Verified_Last);

   function Written_Last (Ctx : Context) return RFLX_Types.Bit_Length is
     (Ctx.Written_Last);

   function Valid_Value (Fld : Field; Val : RFLX_Types.Base_Integer) return Boolean is
     (case Fld is
          when F_Ticket_Lifetime =>
             RFLX.New_Session_Ticket.Valid_Lifetime (Val),
          when F_Ticket_Age_Add =>
             RFLX.New_Session_Ticket.Valid_Age_Add (Val),
          when F_Nonce_Len =>
             RFLX.New_Session_Ticket.Valid_Nonce_Length (Val),
          when F_Ticket_Nonce =>
             True,
          when F_Ticket_Len =>
             RFLX.New_Session_Ticket.Valid_Ticket_Length (Val),
          when F_Ticket =>
             True,
          when F_Extensions_Len =>
             RFLX.New_Session_Ticket.Valid_Extensions_Length (Val),
          when F_Extensions =>
             True);

   function Field_Condition (Ctx : Context; Fld : Field) return Boolean is
     (case Fld is
          when F_Ticket_Lifetime | F_Ticket_Age_Add | F_Nonce_Len | F_Ticket_Nonce | F_Ticket_Len | F_Ticket | F_Extensions_Len | F_Extensions =>
             True);

   function Field_Size (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Length is
     (Field_Size_Internal (Ctx.Cursors, Ctx.First, Ctx.Verified_Last, Ctx.Written_Last, Fld));

   function Field_First (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Index is
     (Field_First_Internal (Ctx.Cursors, Ctx.First, Ctx.Verified_Last, Ctx.Written_Last, Fld));

   function Field_Last (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Length is
     (Field_First (Ctx, Fld) + Field_Size (Ctx, Fld) - 1);

   function Valid_Next (Ctx : Context; Fld : Field) return Boolean is
     (Valid_Next_Internal (Ctx.Cursors, Ctx.First, Ctx.Verified_Last, Ctx.Written_Last, Fld));

   function Available_Space (Ctx : Context; Fld : Field) return RFLX_Types.Bit_Length is
     (Ctx.Last - Field_First (Ctx, Fld) + 1);

   function Sufficient_Space (Ctx : Context; Fld : Field) return Boolean is
     (Available_Space (Ctx, Fld) >= Field_Size (Ctx, Fld));

   function Present (Ctx : Context; Fld : Field) return Boolean is
     (Well_Formed (Ctx.Cursors (Fld))
      and then Ctx.Cursors (Fld).First < Ctx.Cursors (Fld).Last + 1);

   function Well_Formed (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Valid
      or Ctx.Cursors (Fld).State = S_Well_Formed);

   function Valid (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Valid
      and then Ctx.Cursors (Fld).First < Ctx.Cursors (Fld).Last + 1);

   function Incomplete (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Incomplete);

   function Invalid (Ctx : Context; Fld : Field) return Boolean is
     (Ctx.Cursors (Fld).State = S_Invalid
      or Ctx.Cursors (Fld).State = S_Incomplete);

   function Well_Formed_Message (Ctx : Context) return Boolean is
     (Well_Formed (Ctx, F_Extensions));

   function Valid_Message (Ctx : Context) return Boolean is
     (Valid (Ctx, F_Extensions));

   function Incomplete_Message (Ctx : Context) return Boolean is
     ((for some F in Field =>
          Incomplete (Ctx, F)));

   function Get_Ticket_Lifetime (Ctx : Context) return RFLX.New_Session_Ticket.Lifetime is
     (To_Actual (Ctx.Cursors (F_Ticket_Lifetime).Value));

   function Get_Ticket_Age_Add (Ctx : Context) return RFLX.New_Session_Ticket.Age_Add is
     (To_Actual (Ctx.Cursors (F_Ticket_Age_Add).Value));

   function Get_Nonce_Len (Ctx : Context) return RFLX.New_Session_Ticket.Nonce_Length is
     (To_Actual (Ctx.Cursors (F_Nonce_Len).Value));

   function Get_Ticket_Len (Ctx : Context) return RFLX.New_Session_Ticket.Ticket_Length is
     (To_Actual (Ctx.Cursors (F_Ticket_Len).Value));

   function Get_Extensions_Len (Ctx : Context) return RFLX.New_Session_Ticket.Extensions_Length is
     (To_Actual (Ctx.Cursors (F_Extensions_Len).Value));

   function Valid_Size (Ctx : Context; Fld : Field; Size : RFLX_Types.Bit_Length) return Boolean is
     (Size = Field_Size (Ctx, Fld))
   with
     Pre =>
       RFLX.New_Session_Ticket.Message.Valid_Next (Ctx, Fld);

   function Valid_Length (Ctx : Context; Fld : Field; Length : RFLX_Types.Length) return Boolean is
     (Valid_Size (Ctx, Fld, RFLX_Types.To_Bit_Length (Length)));

   function Context_Cursor (Ctx : Context; Fld : Field) return Field_Cursor is
     (Ctx.Cursors (Fld));

   function Context_Cursors (Ctx : Context) return Field_Cursors is
     (Ctx.Cursors);

   function Context_Cursors_Index (Cursors : Field_Cursors; Fld : Field) return Field_Cursor is
     (Cursors (Fld));

   function Valid_Structure (Unused_Struct : Structure) return Boolean is
     (True);

   function Sufficient_Buffer_Length (Ctx : Context; Struct : Structure) return Boolean is
     (RFLX_Types.Base_Integer (RFLX_Types.To_Last_Bit_Index (Ctx.Buffer_Last) - RFLX_Types.To_First_Bit_Index (Ctx.Buffer_First) + 1) >= RFLX_Types.Base_Integer (Struct.Extensions_Len) * 8 + RFLX_Types.Base_Integer (Struct.Nonce_Len) * 8 + RFLX_Types.Base_Integer (Struct.Ticket_Len) * 8 + 104);

   function Field_Size_Ticket_Lifetime (Struct : Structure) return RFLX_Types.Bit_Length is
     (32);

   function Field_Size_Ticket_Age_Add (Struct : Structure) return RFLX_Types.Bit_Length is
     (32);

   function Field_Size_Nonce_Len (Struct : Structure) return RFLX_Types.Bit_Length is
     (8);

   function Field_Size_Ticket_Nonce (Struct : Structure) return RFLX_Types.Bit_Length is
     (RFLX_Types.Bit_Length (Struct.Nonce_Len) * 8);

   function Field_Size_Ticket_Len (Struct : Structure) return RFLX_Types.Bit_Length is
     (16);

   function Field_Size_Ticket (Struct : Structure) return RFLX_Types.Bit_Length is
     (RFLX_Types.Bit_Length (Struct.Ticket_Len) * 8);

   function Field_Size_Extensions_Len (Struct : Structure) return RFLX_Types.Bit_Length is
     (16);

   function Field_Size_Extensions (Struct : Structure) return RFLX_Types.Bit_Length is
     (RFLX_Types.Bit_Length (Struct.Extensions_Len) * 8);

end RFLX.New_Session_Ticket.Message;
