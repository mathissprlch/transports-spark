      Flow_Gate.Op_Packet.Take_Buffer (Ctx.P.Pending_Ctx, Pending_Buffer);
      pragma Warnings (On, """Ctx.P.Pending_Ctx"" is set by ""Take_Buffer"" but not used after the call");
      pragma Assert (Ctx.P.Slots.Slot_Ptr_1 = null);
      pragma Assert (Pending_Buffer /= null);
      Ctx.P.Slots.Slot_Ptr_1 := Pending_Buffer;
      pragma Assert (Ctx.P.Slots.Slot_Ptr_1 /= null);
      pragma Warnings (Off, """Ctx.P.Reply_Ctx"" is set by ""Take_Buffer"" but not used after the call");
      Flow_Gate.Decision_Packet.Take_Buffer (Ctx.P.Reply_Ctx, Reply_Buffer);
      pragma Warnings (On, """Ctx.P.Reply_Ctx"" is set by ""Take_Buffer"" but not used after the call");
      pragma Assert (Ctx.P.Slots.Slot_Ptr_2 = null);
      pragma Assert (Reply_Buffer /= null);
      Ctx.P.Slots.Slot_Ptr_2 := Reply_Buffer;
      pragma Assert (Ctx.P.Slots.Slot_Ptr_2 /= null);
      Flow_Gate.Send_Gate.FSM_Allocator.Finalize (Ctx.P.Slots);
      Ctx.P.Next_State := S_Final;
   end Finalize;

   procedure Reset_Messages_Before_Write (Ctx : in out Context)
   with
     Pre =>
       Initialized (Ctx),
     Post =>
       Initialized (Ctx)
   is
   begin
      case Ctx.P.Next_State is
         when S_Idle =>
            Flow_Gate.Op_Packet.Reset (Ctx.P.Pending_Ctx, Ctx.P.Pending_Ctx.First, Ctx.P.Pending_Ctx.First - 1);
         when S_Dispatch | S_Check_Send | S_Approve_Send | S_Deny_Send | S_Apply_Conn | S_Bump_Conn_OK | S_Apply_Stream | S_Bump_Stream_OK | S_Init_Stream_Window | S_Flow_Error | S_Emit_Decision | S_Final =>
            null;
      end case;
   end Reset_Messages_Before_Write;

   procedure Tick (Ctx : in out Context) is
   begin
      case Ctx.P.Next_State is
         when S_Idle =>
            Idle (Ctx);
         when S_Dispatch =>
            Dispatch (Ctx);
         when S_Check_Send =>
            Check_Send (Ctx);
         when S_Approve_Send =>
            Approve_Send (Ctx);
         when S_Deny_Send =>
            Deny_Send (Ctx);
         when S_Apply_Conn =>
            Apply_Conn (Ctx);
         when S_Bump_Conn_OK =>
            Bump_Conn_OK (Ctx);
         when S_Apply_Stream =>
            Apply_Stream (Ctx);
         when S_Bump_Stream_OK =>
            Bump_Stream_OK (Ctx);
         when S_Init_Stream_Window =>
            Init_Stream_Window (Ctx);
         when S_Flow_Error =>
            Flow_Error (Ctx);
         when S_Emit_Decision =>
            Emit_Decision (Ctx);
         when S_Final =>
            null;
      end case;
      Reset_Messages_Before_Write (Ctx);
   end Tick;

   function In_IO_State (Ctx : Context) return Boolean is
     (Ctx.P.Next_State in S_Idle | S_Emit_Decision);

   procedure Run (Ctx : in out Context) is
   begin
      Tick (Ctx);
      while
         Active (Ctx)
         and not In_IO_State (Ctx)
      loop
         pragma Loop_Invariant (Initialized (Ctx));
         Tick (Ctx);
      end loop;
   end Run;

   procedure Read (Ctx : Context; Chan : Channel; Buffer : out RFLX_Types.Bytes; Offset : RFLX_Types.Length := 0) is
      function Read_Pre (Message_Buffer : RFLX_Types.Bytes) return Boolean is
        (Buffer'Length > 0
         and then Offset < Message_Buffer'Length);
      procedure Read (Message_Buffer : RFLX_Types.Bytes)
      with
        Pre =>
          Read_Pre (Message_Buffer)
      is
         Length : constant RFLX_Types.Length := RFLX_Types.Length'Min (Buffer'Length, Message_Buffer'Length - Offset);
         Buffer_Last : constant RFLX_Types.Index := Buffer'First + (Length - RFLX_Types.Length'(1));
      begin
         Buffer (Buffer'First .. RFLX_Types.Index (Buffer_Last)) := Message_Buffer (RFLX_Types.Index (RFLX_Types.Length (Message_Buffer'First) + Offset) .. Message_Buffer'First + Offset + (Length - RFLX_Types.Length'(1)));
      end Read;
      procedure Flow_Gate_Decision_Packet_Read is new Flow_Gate.Decision_Packet.Generic_Read (Read, Read_Pre);
   begin
      Buffer := (others => 0);
      case Chan is
         when C_App_Outbox =>
            pragma Warnings (Off, "unreachable code");
            null;
            pragma Warnings (On, "unreachable code");
         when C_App_Decision =>
            case Ctx.P.Next_State is
               when S_Emit_Decision =>
                  Flow_Gate_Decision_Packet_Read (Ctx.P.Reply_Ctx);
               when others =>
                  pragma Warnings (Off, "unreachable code");
                  null;
                  pragma Warnings (On, "unreachable code");
            end case;
      end case;
   end Read;

   procedure Write (Ctx : in out Context; Chan : Channel; Buffer : RFLX_Types.Bytes; Offset : RFLX_Types.Length := 0) is
      Write_Buffer_Length : constant RFLX_Types.Length := Write_Buffer_Size (Ctx, Chan);
      function Write_Pre (Context_Buffer_Length : RFLX_Types.Length; Offset : RFLX_Types.Length) return Boolean is
        (Buffer'Length > 0
         and then Context_Buffer_Length = Write_Buffer_Length
         and then Offset <= RFLX_Types.Length'Last - Buffer'Length
         and then Buffer'Length + Offset <= Write_Buffer_Length);
      procedure Write (Message_Buffer : out RFLX_Types.Bytes; Length : out RFLX_Types.Length; Context_Buffer_Length : RFLX_Types.Length; Offset : RFLX_Types.Length)
      with
        Pre =>
          Write_Pre (Context_Buffer_Length, Offset)
          and then Offset <= RFLX_Types.Length'Last - Message_Buffer'Length
          and then Message_Buffer'Length + Offset = Write_Buffer_Length,
        Post =>
          Length <= Message_Buffer'Length
      is
      begin
         Length := Buffer'Length;
         Message_Buffer := (others => 0);
         Message_Buffer (Message_Buffer'First .. RFLX_Types.Index (RFLX_Types.Length (Message_Buffer'First) - 1 + Length)) := Buffer;
      end Write;
      procedure Flow_Gate_Op_Packet_Write is new Flow_Gate.Op_Packet.Generic_Write (Write, Write_Pre);
   begin
      case Chan is
         when C_App_Outbox =>
            case Ctx.P.Next_State is
               when S_Idle =>
                  Flow_Gate_Op_Packet_Write (Ctx.P.Pending_Ctx, Offset);
               when others =>
                  pragma Warnings (Off, "unreachable code");
                  null;
                  pragma Warnings (On, "unreachable code");
            end case;
         when C_App_Decision =>
            pragma Warnings (Off, "unreachable code");
            null;
            pragma Warnings (On, "unreachable code");
      end case;
   end Write;

end RFLX.Flow_Gate.Send_Gate.FSM;
