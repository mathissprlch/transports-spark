# Build artifacts
obj/
lib/
bin/
*.o
*.ali

# Alire
alire/
config/

# Generated code — not committed; regenerated from its source of truth.
#   * RFLX SPARK (mqtt/http2/tls) <- crates/<c>/specs/*.rflx via RecordFlux
#     (CI: pip install RecordFlux + `make rflx-gen`; Mac arm64: scripts/rflx)
#   * protoc-gen-grpc-ada output (examples / protobuf_ada_tests)
#     <- *.proto via `make grpc-codegen`
# A .gitkeep keeps each directory present in a fresh checkout.
crates/examples/generated/*.ad?
!crates/examples/generated/.gitkeep
crates/protobuf_ada_tests/generated/*.ad?
!crates/protobuf_ada_tests/generated/.gitkeep
crates/mqtt_core/generated/*.ad?
!crates/mqtt_core/generated/.gitkeep
crates/http2_core/generated/*.ad?
!crates/http2_core/generated/.gitkeep
crates/tls_core/generated/*.ad?
!crates/tls_core/generated/.gitkeep

# Vendored sources are bootstrapped, not committed.
vendor/aws/

# RecordFlux verification cache
.rflx_cache/

# Editor
.DS_Store
*.swp
.#*
.vscode/
.idea/
.claude/
crates/examples/obj_tls/

# Orphan alr-init scaffolding at repo root (real project lives in crates/)
/src/
/transports-spark.gpr

# Local-only assistant contract; published conventions are in docs/conventions.md
/CLAUDE.md

# Vendored Go reference impls — not part of the SPARK distribution
/bench/go-grpc/

# gnatprove workspace-level session state (only gnatprove.out is the artifact)
/gnatprove/*.tmp
/gnatprove/why3.conf
/gnatprove/data_representation_generation.log
/gnatprove/sessions/
