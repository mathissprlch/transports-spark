--  Internal AWS configuration normally generated by `make setup`.
--  Installed by vendor/bootstrap.sh into vendor/aws/build/projects/aws_config.gpr
--  alongside the os_lib.ads overlay. Zlib is off (we don't need compression
--  for gRPC) and SOCKET is OpenSSL (matches what os_lib.ads was generated with).

abstract project AWS_Config is
   for Source_Dirs use ();

   type Boolean_Type is ("true", "false");
   Zlib_Exists : Boolean_Type := "false";

   type SOCKET_Type is ("std", "openssl", "gnutls");
   SOCKET : SOCKET_Type := "openssl";

end AWS_Config;
